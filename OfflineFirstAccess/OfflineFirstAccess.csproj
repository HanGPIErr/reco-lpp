<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- net8.0-windows is required for OleDb (Windows-only). Library does not need WPF. -->
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>OfflineFirstAccess</RootNamespace>
    <AssemblyName>OfflineFirstAccess</AssemblyName>
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <Platforms>AnyCPU;x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <Configurations>Debug;Release;UAT</Configurations>
    <Deterministic>true</Deterministic>
    <!-- Preserve existing GUID so the .sln keeps resolving the project. -->
    <ProjectGuid>{382BCCAC-6C11-4DCB-BB84-4C09FEC15B6A}</ProjectGuid>
    <!-- Keep parity with the legacy build; SDK-style would otherwise emit IDE0005 etc. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <!-- We keep Properties\AssemblyInfo.cs as the source of truth for assembly attributes
         (Title, Description, Version, Guid). Disable SDK auto-generation so we don't get
         duplicate attribute compile errors. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'UAT' ">
    <OutputPath>bin\UAT\</OutputPath>
    <DefineConstants>TRACE;UAT_ENV</DefineConstants>
    <Optimize>true</Optimize>
    <DebugType>pdbonly</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <!-- OleDb is no longer in the BCL since .NET Core; it's now a separate package.
         Version 9.0.x targets .NET 9, but Microsoft ships matching builds for 8.0 in the same package. -->
    <PackageReference Include="System.Data.OleDb" Version="9.0.0" />
  </ItemGroup>

</Project>
