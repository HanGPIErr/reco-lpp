<Window x:Class="RecoTool.Windows.CommentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comments" Height="480" Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Conversation" Grid.Row="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="ConversationTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Background="Transparent"/>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Header="Add a new comment (type @ to mention a user)" Grid.Row="1" Margin="0,8,0,0">
            <Grid>
                <TextBox x:Name="NewCommentTextBox"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="NewCommentTextBox_TextChanged"
                         PreviewKeyDown="NewCommentTextBox_PreviewKeyDown"/>
                <Popup x:Name="MentionAutocompletePopup" PlacementTarget="{Binding ElementName=NewCommentTextBox}"
                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6"
                            MaxHeight="180" MinWidth="200">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                        </Border.Effect>
                        <ListBox x:Name="MentionListBox" 
                                 BorderThickness="0" Background="Transparent"
                                 MouseDoubleClick="MentionListBox_MouseDoubleClick"
                                 KeyDown="MentionListBox_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,2">
                                        <TextBlock Text="@" Foreground="#3B82F6" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>
        </GroupBox>

        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="AddButton" Content="Add" Width="100" Margin="0,0,8,0" IsDefault="True" Click="AddButton_Click"/>
            <Button Content="Close" Width="100" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
