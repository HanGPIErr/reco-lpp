<UserControl x:Class="RecoTool.Windows.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RecoTool.Windows"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <local:AlertTypeToBorderColorConverter x:Key="AlertTypeToBorderColorConverter"/>
        <local:AlertTypeToIconConverter x:Key="AlertTypeToIconConverter"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ============================================================ -->
        <!-- Unified visual language                                      -->
        <!-- Single corner radius (12), single shadow, consistent spacing -->
        <!-- ============================================================ -->

        <!-- Section header used for every group of cards. Smaller and -->
        <!-- neutral by default so the BNP green stays available for   -->
        <!-- accents (numbers, primary icons) instead of being noise.  -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- Card variant used in the Hero KPI strip — emphasised number, -->
        <!-- short label, accent-colored icon.                            -->
        <Style x:Key="HeroKpiCardStyle" TargetType="Border" BasedOn="{StaticResource KPICardStyle}">
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="MinHeight" Value="92"/>
        </Style>

        <!-- Card-style click button used by ToDoList tiles. Replaces the    -->
        <!-- previous TransparentCardButtonStyle whose hover overlay clashed -->
        <!-- with the card's own background. Keeps the cursor + a faint     -->
        <!-- accent border on hover; the scale animation lives on the outer  -->
        <!-- Border to preserve drop-shadow correctness.                    -->
        <Style x:Key="TodoCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="hoverOverlay" Background="#0A005B46" CornerRadius="12" Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="hoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Backward-compat alias: kept because legacy code-behind may  -->
        <!-- still reference TransparentCardButtonStyle via FindResource. -->
        <Style x:Key="TransparentCardButtonStyle" TargetType="Button" BasedOn="{StaticResource TodoCardButtonStyle}"/>

        <!-- Stat tile inside a ToDo card body — soft pastel background per category.   -->
        <!-- The background colour is set inline by each tile (we can't parametrise a   -->
        <!-- Style with per-instance values cleanly). Default = neutral grey for the    -->
        <!-- "no specific category" case.                                              -->
        <Style x:Key="TodoStatTileStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Padding" Value="9,6"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" Background="{DynamicResource BNPBackground}" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16,20,24">

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- UAT BANNER — unchanged behaviour: toggled from code-behind  -->
            <!-- when the build is the UAT configuration.                    -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <Border x:Name="UatBanner" Visibility="Collapsed" Background="#D32F2F" CornerRadius="8" Padding="14,8" Margin="0,0,0,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="⚠️" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="UAT ENVIRONMENT" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" — " FontSize="15" Foreground="#FFCDD2" VerticalAlignment="Center"/>
                    <TextBlock Text="This is a test environment. Data is not production." FontSize="12" Foreground="#FFCDD2" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- HERO ZONE                                                   -->
            <!--   Row 1: title + actions                                    -->
            <!--   Row 2: DWINGS freshness pill (only when stale)            -->
            <!--   Row 3: 4-tile KPI strip — the only "at a glance" numbers  -->
            <!-- ════════════════════════════════════════════════════════════ -->

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Dashboard" FontSize="26" FontWeight="SemiBold" Foreground="{DynamicResource BNPMainGreenBrush}"/>
                    <TextBlock Text="Reconciliation overview" FontSize="13" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" ItemHeight="38" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Height="38" MinWidth="150" Style="{StaticResource StandardButtonStyle}" Click="ImportAmbre_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Import Ambre" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Height="38" MinWidth="150" Style="{StaticResource StandardButtonStyle}" Click="OpenReports_Click" Margin="0,0,8,0"
                            ToolTip="Exports a multi-sheet Excel dashboard (KPIs, breakdowns, alerts, all reconciliations) for the selected country.">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Export Dashboard" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Height="38" MinWidth="150" Style="{StaticResource StandardButtonStyle}" Click="ExportDailyKpi_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Export Daily KPI" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>

            <!-- DWINGS freshness pill — collapsed when data is fresh, full   -->
            <!-- warning only when stale. Less visually loud than the legacy  -->
            <!-- yellow banner since the screen now has a dedicated KPI strip -->
            <!-- right below it.                                              -->
            <Border CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                    Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1"
                    Visibility="{Binding IsDwingsDataFromToday, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#B45309" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="DWINGS data is not from today" FontWeight="SemiBold" Foreground="#92400E" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text=" — " Foreground="#92400E" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DwingsWarningMessage}" Foreground="#92400E" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="800"/>
                </StackPanel>
            </Border>

            <!-- HERO KPI strip — 4 tiles in one row. Numbers are big and dark, -->
            <!-- labels are small grey, icons use the BNP accent. Replaces both -->
            <!-- the legacy "QUICK STATS" section and the in-card metric clutter -->
            <!-- as the single source of "at a glance" totals.                  -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource HeroKpiCardStyle}" Margin="0,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#EFF6FF" CornerRadius="8" Width="38" Height="38" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#1D4ED8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalLiveCount, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Total live items" FontSize="11" Foreground="#6B7280"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Replaced "Matched to DWINGS %" (== "will be archived tomorrow", -->
                <!-- so largely a duplicate of upcoming archive count) with         -->
                <!-- "Missing invoices" — actionable backlog of unlinked rows that  -->
                <!-- need an invoice link before they can flow through the rules.  -->
                <Border Grid.Column="1" Style="{StaticResource HeroKpiCardStyle}" Margin="6,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FEF2F2" CornerRadius="8" Width="38" Height="38" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#B91C1C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MissingInvoicesCount, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Missing invoices" FontSize="11" Foreground="#6B7280"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource HeroKpiCardStyle}" Margin="6,0,6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FFF7ED" CornerRadius="8" Width="38" Height="38" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#C2410C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TotalToReviewCount, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="To review" FontSize="11" Foreground="#6B7280"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource HeroKpiCardStyle}" Margin="6,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F5F3FF" CornerRadius="8" Width="38" Height="38" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="&#xE73A;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="#6D28D9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ReviewedTodayCount, StringFormat='{}{0:N0}'}" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Reviewed today" FontSize="11" Foreground="#6B7280"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- ALERTS — promoted to right after the Hero so they push       -->
            <!-- the user to action. Collapsed entirely when the source       -->
            <!-- collection is empty (no Visibility binding needed; an        -->
            <!-- ItemsControl with 0 items takes zero vertical space).        -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <ItemsControl ItemsSource="{Binding AlertItems}" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Padding="14,10" Margin="0,0,10,10"
                                Effect="{StaticResource LightShadow}"
                                BorderThickness="1,1,1,1"
                                BorderBrush="{Binding Type, Converter={StaticResource AlertTypeToBorderColorConverter}}"
                                MinWidth="260">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="32" Height="32" CornerRadius="8" Background="#F9FAFB" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Type, Converter={StaticResource AlertTypeToIconConverter}}"
                                               FontFamily="Segoe MDL2 Assets" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Foreground="{Binding Type, Converter={StaticResource AlertTypeToBorderColorConverter}}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                                    <TextBlock Text="{Binding Message}" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0" MaxWidth="280" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Count}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="14,0,0,0"
                                           Foreground="{Binding Type, Converter={StaticResource AlertTypeToBorderColorConverter}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- BODY — TODO LISTS                                            -->
            <!-- The main "work hub". Each card opens a filtered view.        -->
            <!-- Visual is simplified vs the legacy 4-gradient grid: header   -->
            <!-- pill with accent, 4 flat stat tiles, footer with totals.     -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <TextBlock Text="MY TO-DO LISTS" Style="{StaticResource SectionHeaderStyle}"/>
            <ItemsControl ItemsSource="{Binding TodoCards}" HorizontalAlignment="Left" Margin="0,0,0,18">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,14,16" CornerRadius="14" Background="White" Width="215" x:Name="cardBorder"
                                BorderThickness="1" BorderBrush="#E5E7EB">
                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="cardScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <!-- Slightly more pronounced shadow for visual depth (was 16/0.18 → -->
                            <!-- now 20/0.22), with a green-tinted colour that picks up the BNP   -->
                            <!-- accent and feels less "office paperwork".                       -->
                            <Border.Effect>
                                <DropShadowEffect x:Name="cardShadow" BlurRadius="20" ShadowDepth="3" Opacity="0.22" Direction="270" Color="#064E3B"/>
                            </Border.Effect>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleX" To="1.035" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleY" To="1.035" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="cardShadow" Storyboard.TargetProperty="BlurRadius" To="32" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="cardShadow" Storyboard.TargetProperty="Opacity" To="0.45" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="cardShadow" Storyboard.TargetProperty="BlurRadius" To="20" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="cardShadow" Storyboard.TargetProperty="Opacity" To="0.22" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Button Style="{StaticResource TodoCardButtonStyle}" Click="OpenTodoCard_Click" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header: ToDo name + presence badge, on a richer gradient -->
                                    <!-- with a subtle inset highlight at the top. Folder icon on -->
                                    <!-- the left brings back a hint of the legacy iconography.   -->
                                    <Border Grid.Row="0" CornerRadius="14,14,0,0" Padding="14,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{Binding Source={StaticResource BNPMainGreenBrush}, Path=Color}" Offset="0"/>
                                                <GradientStop Color="#0D5044" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#26FFFFFF" CornerRadius="7" Width="28" Height="28" Margin="0,0,10,0">
                                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Item.TDL_Name}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2" CornerRadius="10" Padding="6,3" VerticalAlignment="Center"
                                                    Visibility="{Binding HasActiveUsers, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Background="{Binding ActiveUsersBadgeBackground}"
                                                    ToolTip="{Binding ActiveUsersTooltip}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Foreground="#1F2937" Margin="0,0,3,0"/>
                                                    <TextBlock Text="{Binding ActiveUsersText}" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#1F2937"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Body: 2x2 grid of stat tiles with soft pastel backgrounds -->
                                    <!-- per category (vs the previous loud full-saturation gradient).  -->
                                    <!-- Numbers are large and coloured to match the category accent;  -->
                                    <!-- labels stay neutral grey so the eye lands on the number.      -->
                                    <Grid Grid.Row="1" Margin="11,11,11,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- New -->
                                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TodoStatTileStyle}" Background="#FEF3C7" Margin="0,0,4,4">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Foreground="#B45309" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="New" FontSize="10" Foreground="#92400E" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding NewCount, StringFormat='{}{0:N0}'}" FontSize="19" FontWeight="Bold" Foreground="#92400E" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- To link -->
                                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource TodoStatTileStyle}" Background="#FEE2E2" Margin="4,0,0,4">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" Foreground="#B91C1C" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="To link" FontSize="10" Foreground="#991B1B" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding NotLinkedCount, StringFormat='{}{0:N0}'}" FontSize="19" FontWeight="Bold" Foreground="#991B1B" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- To review -->
                                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource TodoStatTileStyle}" Background="#FFEDD5" Margin="0,4,4,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Foreground="#C2410C" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="To review" FontSize="10" Foreground="#9A3412" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Count, StringFormat='{}{0:N0}'}" FontSize="19" FontWeight="Bold" Foreground="#9A3412" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Done -->
                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource TodoStatTileStyle}" Background="#D1FAE5" Margin="4,4,0,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#047857" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Done" FontSize="10" Foreground="#065F46" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ReviewedCount, StringFormat='{}{0:N0}'}" FontSize="19" FontWeight="Bold" Foreground="#065F46" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Footer: Total + Amount + thin progress bar (Done/Total).   -->
                                    <!-- The bar gives instant visual context for "how far along"  -->
                                    <!-- without occupying a full new row of numbers.              -->
                                    <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="0,0,14,14" Padding="12,8,12,10" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                                                    <TextBlock Text="TOTAL" FontSize="9" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding ActualTotal, StringFormat='{}{0:N0}'}" FontSize="14" FontWeight="Bold" Foreground="#111827"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="AMOUNT" FontSize="9" Foreground="#9CA3AF" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding AmountsText}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BNPMainGreenBrush}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- Thin progress track for Done/Total. Maximum is bound to ActualTotal -->
                                            <!-- with a tiny offset (0.0001) so a brand-new ToDo with 0/0 still renders -->
                                            <!-- the empty bar instead of throwing on Maximum=0.                        -->
                                            <Border CornerRadius="3" Background="#E5E7EB" Height="4">
                                                <ProgressBar Background="Transparent" BorderThickness="0"
                                                             Foreground="{DynamicResource BNPMainGreenBrush}"
                                                             Minimum="0" Maximum="{Binding ActualTotal}"
                                                             Value="{Binding ReviewedCount, Mode=OneWay}"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Button>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- ACCOUNT OVERVIEW (compact)                                   -->
            <!-- Stripped down from the legacy 250px-tall section to a single -->
            <!-- card with Receivable | Pivot side-by-side: count + amount.   -->
            <!-- No chart (the by-currency breakdown lives in DISTRIBUTION).  -->
            <!-- ════════════════════════════════════════════════════════════ -->
            <TextBlock Text="ACCOUNT OVERVIEW" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource KPICardStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Receivable side -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#EFF6FF" CornerRadius="8" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#1D4ED8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Receivable" FontSize="11" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ReceivableAccountsCount, StringFormat='{}{0:N0}'}" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                                <TextBlock Text=" lines" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="3,0,0,2"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalReceivableAmount}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BNPMainGreenBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Column="1" Width="1" Background="#E5E7EB" Margin="20,4"/>

                    <!-- Pivot side -->
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#F5F3FF" CornerRadius="8" Width="40" Height="40" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#6D28D9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Pivot" FontSize="11" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PivotAccountsCount, StringFormat='{}{0:N0}'}" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                                <TextBlock Text=" lines" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="3,0,0,2"/>
                            </StackPanel>
                            <TextBlock Text="{Binding TotalPivotAmount}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BNPMainGreenBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- ANALYTICS — Trends (2-col) + Distribution (3-col)            -->
            <!-- Reduced from the legacy "HISTORICAL TRENDS" (2 charts) +     -->
            <!-- "REVIEW TRENDS" (2 charts) + "WORK DISTRIBUTION" (3 charts)  -->
            <!-- which together took ~750px of vertical space. Now folded     -->
            <!-- into two compact rows. "Avg time to archive" was dropped     -->
            <!-- — too domain-specific for the dashboard surface.             -->
            <!-- ════════════════════════════════════════════════════════════ -->

            <TextBlock Text="TRENDS" Style="{StaticResource SectionHeaderStyle}"/>
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource KPICardStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="New vs Archived" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="Daily, last period" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Height="180" DisableAnimations="True" Series="{Binding NewDeletedDailySeries}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding NewDeletedDailyLabels}" FontSize="10">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis FontSize="10">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource KPICardStyle}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Matched rate" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="% linked to DWINGS — last 7 days" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Height="180" DisableAnimations="True" Series="{Binding MatchedRateTrendSeries}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding MatchedRateTrendLabels}" FontSize="10">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis FontSize="10" MinValue="0" MaxValue="100">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Text="REVIEW ACTIVITY" Style="{StaticResource SectionHeaderStyle}"/>
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource KPICardStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="Reviews per day" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="Last 7 days" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Height="180" DisableAnimations="True" Series="{Binding ReviewTrendSeries}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding ReviewTrendLabels}" FontSize="10">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis FontSize="10">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource KPICardStyle}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="By action" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="Volume total" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Height="180" DisableAnimations="True" Series="{Binding ActionDistributionSeries}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding ActionLabels}" FontSize="10">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis FontSize="10">
                                    <lvc:Axis.Separator><lvc:Separator IsEnabled="False"/></lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Text="DISTRIBUTION" Style="{StaticResource SectionHeaderStyle}"/>
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource KPICardStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="By KPI" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="Volume total" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <!-- KPIChart x:Name preserved — populated from code-behind l.2028 -->
                        <lvc:PieChart x:Name="KPIChart" Grid.Row="1" Height="200" DisableAnimations="True" LegendLocation="Bottom"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource KPICardStyle}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="By currency" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="Abs solde net" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <lvc:PieChart Grid.Row="1" Height="200" DisableAnimations="True"
                                      Series="{Binding CurrencyDistributionSeries}" LegendLocation="Bottom"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════════════════════════════════════════════════════════════ -->
            <!-- FOOTER — Team & Progress                                     -->
            <!-- Assignee leaderboard (compact) + Completion estimate with    -->
            <!-- progress bar. Less visually emphasised because these are     -->
            <!-- consulted, not driven.                                       -->
            <!-- ════════════════════════════════════════════════════════════ -->

            <TextBlock Text="TEAM &amp; PROGRESS" Style="{StaticResource SectionHeaderStyle}"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Compact leaderboard: 1 row per assignee, name + count + rate -->
                <Border Grid.Column="0" Style="{StaticResource KPICardStyle}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Assignee leaderboard" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="This week" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding AssigneeLeaderboard}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" Background="#F3F4F6" Margin="0,0,10,0">
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource BNPMainGreenBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Assignee}" FontSize="12" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ReviewedThisWeek}" FontSize="14" FontWeight="Bold" Foreground="#111827"/>
                                            <TextBlock Text=" reviewed" FontSize="10" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text="{Binding CompletionRate, StringFormat='{}{0:N1}%'}" FontSize="12" FontWeight="SemiBold" Foreground="#047857" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Completion progress: progress bar replacing the legacy 4    -->
                <!-- vertical "stat columns" so the user can read progress in   -->
                <!-- one glance. Three quick metrics underneath as captions.    -->
                <Border Grid.Column="1" Style="{StaticResource KPICardStyle}" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Completion estimate" FontSize="13" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock Text="Backlog burn-down at current pace" FontSize="11" Foreground="#9CA3AF"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CompletionEstimate.CompletionPercentage, StringFormat='{}{0:N1}% complete'}" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                                <TextBlock Text="{Binding CompletionEstimate.EstimatedDaysToComplete, StringFormat='~{0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#6D28D9" VerticalAlignment="Center"/>
                                <TextBlock Text=" days left" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                            </StackPanel>
                        </Grid>

                        <ProgressBar Grid.Row="2" Height="10" Minimum="0" Maximum="100"
                                     Value="{Binding CompletionEstimate.CompletionPercentage, Mode=OneWay}"
                                     Foreground="{DynamicResource BNPMainGreenBrush}" Background="#F3F4F6" BorderThickness="0" Margin="0,0,0,12"/>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="To review" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CompletionEstimate.UnreviewedCount, StringFormat='{}{0:N0}'}" FontSize="16" FontWeight="Bold" Foreground="#C2410C"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Daily rate" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CompletionEstimate.DailyReviewRate, StringFormat='{}{0:N1}/day'}" FontSize="16" FontWeight="Bold" Foreground="#1D4ED8"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status / last-updated. Single low-noise line. Replaces the   -->
            <!-- legacy full-width "Recent Activity" card that contained the  -->
            <!-- same two pieces of information.                              -->
            <Border CornerRadius="8" Background="Transparent" Padding="0,4,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding LastUpdateTime, StringFormat='Last updated: {0:dd/MM/yyyy HH:mm}'}" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
