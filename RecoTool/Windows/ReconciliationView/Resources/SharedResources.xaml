<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:RecoTool.Windows">
    <!--
        Shared templates + converters used across ReconciliationView.
        Only items actually referenced by the grid/popup XAML remain here.
        Row-colour / bool-to-text conversions were replaced by pre-calculated DTO properties
        (see ReconciliationViewData.Recalc* helpers) for better scroll performance.
    -->

    <!-- Renders a single UserField option row inside ComboBox pickers; the null entry
         shows up as an empty TextBlock, letting the user clear a previously-chosen value. -->
    <DataTemplate x:Key="UserFieldItemTemplate">
        <TextBlock>
            <TextBlock.Text>
                <Binding Path="USR_FieldName"/>
            </TextBlock.Text>
        </TextBlock>
    </DataTemplate>

    <!-- Converters referenced from XAML. Instantiated once and cached by WPF. -->
    <local:UserFieldOptionsConverter x:Key="UserFieldOptionsConverter"/>
    <BooleanToVisibilityConverter    x:Key="BoolToVisibilityConverter"/>
</ResourceDictionary>
