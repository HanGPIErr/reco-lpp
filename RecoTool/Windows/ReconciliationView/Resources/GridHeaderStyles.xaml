<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:syncfusion="http://schemas.syncfusion.com/wpf">
    <!--
        Grid header brushes + styles for ReconciliationView.
        Colour families signal the data source of each column group:
          • Blue   = AMBRE
          • Green  = T_Reconciliation (user-edited)
          • Orange = DWINGS Invoice
          • Purple = DWINGS Guarantee
          • Slate  = Default fallback
        Every brush is frozen via po:Freeze="True" to avoid GC/COM pressure during horizontal scroll.
    -->

    <!-- ── AMBRE (blue) ───────────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="AmbreHeaderBg" po:Freeze="True" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E3F2FD" Offset="0"/>
        <GradientStop Color="#BBDEFB" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AmbreHeaderFg"     po:Freeze="True" Color="#0D47A1"/>
    <SolidColorBrush x:Key="AmbreHeaderBorder" po:Freeze="True" Color="#90CAF9"/>

    <!-- ── User (green) ───────────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="UserHeaderBg" po:Freeze="True" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E8F5E9" Offset="0"/>
        <GradientStop Color="#C8E6C9" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="UserHeaderFg"     po:Freeze="True" Color="#1B5E20"/>
    <SolidColorBrush x:Key="UserHeaderBorder" po:Freeze="True" Color="#81C784"/>

    <!-- ── DWINGS Invoice (orange) ────────────────────────────────────── -->
    <LinearGradientBrush x:Key="DWInvoiceHeaderBg" po:Freeze="True" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFF3E0" Offset="0"/>
        <GradientStop Color="#FFE0B2" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DWInvoiceHeaderFg"     po:Freeze="True" Color="#E65100"/>
    <SolidColorBrush x:Key="DWInvoiceHeaderBorder" po:Freeze="True" Color="#FFB74D"/>

    <!-- ── DWINGS Guarantee (purple) ──────────────────────────────────── -->
    <LinearGradientBrush x:Key="DWGuaranteeHeaderBg" po:Freeze="True" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F3E5F5" Offset="0"/>
        <GradientStop Color="#E1BEE7" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DWGuaranteeHeaderFg"     po:Freeze="True" Color="#4A148C"/>
    <SolidColorBrush x:Key="DWGuaranteeHeaderBorder" po:Freeze="True" Color="#BA68C8"/>

    <!-- ── Default header fallback (slate) ────────────────────────────── -->
    <LinearGradientBrush x:Key="DefaultHeaderBg" po:Freeze="True" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F1F5F9" Offset="0"/>
        <GradientStop Color="#E2E8F0" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DefaultHeaderFg"          po:Freeze="True" Color="#334155"/>
    <SolidColorBrush x:Key="DefaultHeaderBorderBrush" po:Freeze="True" Color="#CBD5E1"/>

    <!--
        SfDataGrid column-header styles (one per source family).
        All share: semibold, 8/6 padding, bottom+right border for the visual divider.
        Differ only in brushes + ToolTip.
    -->
    <Style x:Key="DefaultGridHeaderStyle" TargetType="syncfusion:GridHeaderCellControl">
        <Setter Property="Background" Value="{StaticResource DefaultHeaderBg}"/>
        <Setter Property="Foreground" Value="{StaticResource DefaultHeaderFg}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="{StaticResource DefaultHeaderBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,2"/>
    </Style>

    <Style x:Key="AmbreHeaderStyle" TargetType="syncfusion:GridHeaderCellControl">
        <Setter Property="Background" Value="{StaticResource AmbreHeaderBg}"/>
        <Setter Property="Foreground" Value="{StaticResource AmbreHeaderFg}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="{StaticResource AmbreHeaderBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,1,2"/>
        <Setter Property="ToolTip" Value="Source: AMBRE"/>
    </Style>

    <Style x:Key="UserHeaderStyle" TargetType="syncfusion:GridHeaderCellControl">
        <Setter Property="Background" Value="{StaticResource UserHeaderBg}"/>
        <Setter Property="Foreground" Value="{StaticResource UserHeaderFg}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="{StaticResource UserHeaderBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,1,2"/>
        <Setter Property="ToolTip" Value="Source: T_Reconciliation (User Data)"/>
    </Style>

    <Style x:Key="DWInvoiceHeaderStyle" TargetType="syncfusion:GridHeaderCellControl">
        <Setter Property="Background" Value="{StaticResource DWInvoiceHeaderBg}"/>
        <Setter Property="Foreground" Value="{StaticResource DWInvoiceHeaderFg}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="{StaticResource DWInvoiceHeaderBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,1,2"/>
        <Setter Property="ToolTip" Value="Source: DWINGS Invoice"/>
    </Style>

    <Style x:Key="DWGuaranteeHeaderStyle" TargetType="syncfusion:GridHeaderCellControl">
        <Setter Property="Background" Value="{StaticResource DWGuaranteeHeaderBg}"/>
        <Setter Property="Foreground" Value="{StaticResource DWGuaranteeHeaderFg}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderBrush" Value="{StaticResource DWGuaranteeHeaderBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,1,2"/>
        <Setter Property="ToolTip" Value="Source: DWINGS Guarantee"/>
    </Style>
</ResourceDictionary>
