<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                    xmlns:local="clr-namespace:RecoTool.Windows">
    <!--
        SfDataGrid row + cell + selection styling.
        Backgrounds/foregrounds come from pre-calculated brush properties on the DTO
        (RowBackgroundBrush / RowForegroundBrush) so the grid pays zero conversion cost
        during scroll. See ReconciliationViewData.Recalc* methods.

        Font inheritance: intentionally NOT set here — FontFamily/FontSize are inherited
        from the SfDataGrid parent, which saves N property-change notifications per row recycle.
    -->

    <!-- Selection + grid-line brushes (frozen) -->
    <SolidColorBrush x:Key="GridSelectionBrush" po:Freeze="True" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="GridSelectionFg"    po:Freeze="True" Color="#1E293B"/>
    <SolidColorBrush x:Key="GridLineBrush"      po:Freeze="True" Color="#E2E8F0"/>

    <!--
        Per-cell "changed since last import" signal. Each converter takes a MultiBinding of
        [DataContext (ReconciliationViewData), ColumnBase.GridColumn.MappingName] and resolves
        the matching RowChange entry in O(1) via ReconciliationViewData.GetChangeForField.
    -->
    <local:CellChangedBackgroundConverter x:Key="CellChangedBackgroundConverter"/>
    <local:CellChangedTooltipConverter    x:Key="CellChangedTooltipConverter"/>
    <local:CellChangedCursorConverter     x:Key="CellChangedCursorConverter"/>

    <!--
        Row style (one instance per visible row via VirtualizingStackPanel recycling).
        Brushes are bound directly to the row's DTO — SetBinding happens once per container,
        refreshes are driven by INotifyPropertyChanged when the DTO recalculates its state.
    -->
    <Style TargetType="syncfusion:VirtualizingCellsControl">
        <Setter Property="Background" Value="{Binding RowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{Binding RowForegroundBrush}"/>
        <!--
            Left edge: 3 px coloured only when the DTO's ActivityIndicatorBrush resolves to a
            non-transparent brush (rows that have changed since the latest import snapshot).
            The brush getter is a single static-brush branch on HasRecentActivity, so there is no
            allocation cost per-row.
        -->
        <Setter Property="BorderBrush" Value="{Binding ActivityIndicatorBrush}"/>
        <Setter Property="BorderThickness" Value="3,0,0,0"/>
        <Style.Triggers>
            <!--
                Tooltip is only attached when the row has actually changed since the last
                snapshot. Keeps the hit-test path free on unchanged rows (WPF will not
                instantiate the ToolTip visual tree until the DataTrigger fires).
            -->
            <DataTrigger Binding="{Binding HasRecentActivity}" Value="True">
                <Setter Property="ToolTipService.InitialShowDelay" Value="350"/>
                <Setter Property="ToolTipService.ShowDuration" Value="20000"/>
                <Setter Property="ToolTip">
                    <Setter.Value>
                        <!--
                            ToolTip visual is re-used across rows (WPF pools it on a per-Style basis)
                            so the DataContext reflects the currently-hovered row at display time.
                            Fixed width keeps the content readable without truncating the grid below.
                        -->
                        <Border Background="White"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,10"
                                MaxWidth="520">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE7C3;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"
                                               UseLayoutRounding="True"
                                               TextOptions.TextFormattingMode="Display"/>
                                    <!--
                                        Header shows the actual import timestamp (local time).
                                        LastImportDateDisplay is empty when the row has no recent
                                        activity — StringFormat + FallbackValue keep the header
                                        readable in the unlikely case a change slips through
                                        without a timestamp.
                                    -->
                                    <TextBlock Text="{Binding LastImportDateDisplay, StringFormat='Changed on {0}', TargetNullValue='Changed since last import', FallbackValue='Changed since last import'}"
                                               FontWeight="SemiBold"
                                               Foreground="#1E293B"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Per-field diff list. Empty for archived / added markers; those
                                     produce no FieldChanged entries so the ItemsControl simply
                                     shows nothing — the header line above covers the other kinds. -->
                                <ItemsControl ItemsSource="{Binding RecentChanges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding FieldName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#475569"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Border Background="#FEE2E2"
                                                            CornerRadius="3"
                                                            Padding="4,1"
                                                            Margin="0,0,4,0">
                                                        <TextBlock Text="{Binding OldValue, TargetNullValue='(empty)', FallbackValue='(empty)'}"
                                                                   Foreground="#991B1B"
                                                                   FontSize="11"
                                                                   MaxWidth="140"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                    <TextBlock Text="&#x2192;"
                                                               Foreground="#64748B"
                                                               FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,4,0"/>
                                                    <Border Background="#DCFCE7"
                                                            CornerRadius="3"
                                                            Padding="4,1">
                                                        <TextBlock Text="{Binding NewValue, TargetNullValue='(empty)', FallbackValue='(empty)'}"
                                                                   Foreground="#166534"
                                                                   FontSize="11"
                                                                   MaxWidth="140"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--
        Cell style: subtle 0.5px right border for vertical separators + minimal padding.
        Vertical content is centred so numeric cells line up with text cells.

        Changed-since-last-import signal:
          • Background tint — amber-50 on cells whose field appears in the row's RecentChanges.
          • ToolTip — "Was: x / Now: y" shown on hover; falls through to the row tooltip when
            the converter returns UnsetValue (unchanged cells).
        Columns with their own CellStyle (Action / KPI / Status / user-field popups) override this
        base style completely, so they keep their semantic colouring — the row border + row
        tooltip continue to signal the change for those cells.
    -->
    <Style TargetType="syncfusion:GridCell">
        <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0.5,0"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background">
            <Setter.Value>
                <MultiBinding Converter="{StaticResource CellChangedBackgroundConverter}" Mode="OneWay">
                    <Binding/>
                    <Binding Path="ColumnBase.GridColumn.MappingName" RelativeSource="{RelativeSource Self}"/>
                </MultiBinding>
            </Setter.Value>
        </Setter>
        <Setter Property="ToolTip">
            <Setter.Value>
                <MultiBinding Converter="{StaticResource CellChangedTooltipConverter}" Mode="OneWay">
                    <Binding/>
                    <Binding Path="ColumnBase.GridColumn.MappingName" RelativeSource="{RelativeSource Self}"/>
                </MultiBinding>
            </Setter.Value>
        </Setter>
        <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
        <Setter Property="ToolTipService.ShowDuration" Value="15000"/>
        <!--
            Cursor flips to Help on changed cells — standard Windows convention for
            "hover here for more info". On unchanged cells the converter returns UnsetValue
            so the default cell cursor wins (pointer / I-beam when editing, etc.).
        -->
        <Setter Property="Cursor">
            <Setter.Value>
                <MultiBinding Converter="{StaticResource CellChangedCursorConverter}" Mode="OneWay">
                    <Binding/>
                    <Binding Path="ColumnBase.GridColumn.MappingName" RelativeSource="{RelativeSource Self}"/>
                </MultiBinding>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
