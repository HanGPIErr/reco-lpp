<UserControl x:Class="RecoTool.Windows.ReconciliationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RecoTool.Windows"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
                mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <!-- Force ComboBoxItem alignment to avoid theme templates using ancestor bindings that may fail during dynamic updates -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BNPBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Compact Ribbon for Reconciliation Page -->
        <Border Grid.Row="0" Background="White" Padding="12,6" Effect="{StaticResource StandardShadow}" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- View Management Section -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                    <Border Background="{DynamicResource BNPMainGreenBrush}" CornerRadius="6" Padding="10,6" Effect="{StaticResource LightShadow}">
                        <Button Style="{StaticResource StandardButtonStyle}" Click="AddView_Click" IsEnabled="{Binding CanInteract}" Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center">
                                    <Run Text="Add View"/>
                                    <Run Text=" " />
                                    <Run Text="{Binding AddViewModeIndicator, Mode=OneWay}" FontSize="11" FontWeight="Normal"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Border>
                </StackPanel>

                <!-- ToDo Management Section -->
                <Border Grid.Column="1" Background="#F8F9FA" CornerRadius="6" Padding="10,6" Margin="0,0,8,0" BorderBrush="#DEE2E6" BorderThickness="1" Effect="{StaticResource LightShadow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource BNPMainGreenBrush}"/>
                        <TextBlock Text="ToDo:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="TodoListComboBox" Width="127" Style="{StaticResource ModernComboBoxStyle}"
                                  ItemsSource="{Binding TodoItems}"
                                  DisplayMemberPath="TDL_Name"
                                  SelectedItem="{Binding SelectedTodoItem, Mode=TwoWay}"
                                  SelectionChanged="TodoListComboBox_SelectionChanged"
                                  HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        <TextBox x:Name="TodoNameTextBox" Width="80" Margin="8,0,0,0" MaxLines="1" VerticalContentAlignment="Center" Text="{Binding EditTodoName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Style="{StaticResource StandardButtonStyle}" Margin="8,0,0,0" Height="26" Padding="10,0" Click="TodoAdd_Click" Visibility="Collapsed"><TextBlock Text="Add"/></Button>
                        <Button Style="{StaticResource StandardButtonStyle}" Margin="4,0,0,0" Height="26" Padding="10,0" Click="TodoSave_Click" Visibility="Collapsed"><TextBlock Text="Save"/></Button>
                        <Button Style="{StaticResource StandardButtonStyle}" Margin="4,0,0,0" Height="26" Padding="10,0" Click="TodoDelete_Click" Visibility="Collapsed">
                            <TextBlock Text="Delete"/>
                        </Button>
                        <Button Style="{StaticResource StandardButtonStyle}" Margin="8,0,0,0" Height="26" Padding="10,0" Click="TodoExit_Click" ToolTip="Exit ToDo mode" Visibility="{Binding IsTodoMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Exit ToDo"/>
                        </Button>
                        <!-- Multi-user indicator for current TodoList item -->
                        <Border x:Name="TodoMultiUserBadge" Visibility="Collapsed" Background="#FFF3E0" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" BorderBrush="#FFB74D" BorderThickness="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#E65100" VerticalAlignment="Center" Margin="0,0,4,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <TextBlock x:Name="TodoMultiUserText" Text="" FontSize="11" Foreground="#E65100" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Data Scope Section -->
                <Border Grid.Column="2" Background="#F8F9FA" CornerRadius="6" Padding="10,6" Margin="0,0,8,0" BorderBrush="#DEE2E6" BorderThickness="1" Effect="{StaticResource LightShadow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource BNPMainGreenBrush}" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                        <ComboBox x:Name="AccountComboBox" Width="90" ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount, Mode=TwoWay}" IsEditable="False" Style="{StaticResource ModernComboBoxStyle}" IsEnabled="{Binding CanChangeAccount}"
                                  HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        <Rectangle Width="1" Height="24" Fill="#DEE2E6" Margin="12,0"/>
                        <ComboBox x:Name="StatusComboBoxInline" Width="80" ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus, Mode=TwoWay}" IsEditable="False" Style="{StaticResource ModernComboBoxStyle}" IsEnabled="{Binding CanChangeStatus}"
                                  HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Saved Items Section -->
                <Border Grid.Column="3" Background="#F8F9FA" CornerRadius="6" Padding="10,6" Margin="0,0,8,0" BorderBrush="#DEE2E6" BorderThickness="1" Effect="{StaticResource LightShadow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource BNPMainGreenBrush}" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                        <ComboBox x:Name="SavedFiltersComboBox" Width="130" Style="{StaticResource ModernComboBoxStyle}" IsEnabled="{Binding CanUseSavedControls}"
                                  ItemsSource="{Binding SavedFilters}"
                                  DisplayMemberPath="UFI_Name"
                                  SelectionChanged="SavedFiltersComboBox_SelectionChanged"
                                  HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        <Rectangle Width="1" Height="24" Fill="#DEE2E6" Margin="12,0"/>
                        <TextBlock Text="View:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="SavedViewsComboBox" Width="130" Style="{StaticResource ModernComboBoxStyle}" IsEnabled="{Binding CanUseSavedControls}"
                                  ItemsSource="{Binding SavedViews}"
                                  SelectedItem="{Binding SelectedSavedView, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="SavedViewsComboBox_SelectionChanged"
                                  HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- View Type & Tools Section -->
                <Border Grid.Column="4" Background="#F8F9FA" CornerRadius="6" Padding="10,6" Margin="0,0,8,0" BorderBrush="#DEE2E6" BorderThickness="1" Effect="{StaticResource LightShadow}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource BNPMainGreenBrush}" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                        <ComboBox x:Name="ViewTypeComboBox" Width="90" ItemsSource="{Binding ViewTypes}" SelectedItem="{Binding SelectedViewType, Mode=TwoWay}" IsEditable="False" Style="{StaticResource ModernComboBoxStyle}" IsEnabled="{Binding CanInteract}"
                                  HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <StackPanel Grid.Column="5" Orientation="Horizontal">
                    <Button Style="{StaticResource StandardButtonStyle}" Padding="10,6" Click="OpenInvoiceFinder_Click" IsEnabled="{Binding CanInteract}" ToolTip="Open Invoice Finder" Background="#F0F7FF" BorderBrush="#2196F3" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Invoice Finder" FontSize="12" Foreground="#2196F3" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ShortcutsToggleBtn" Style="{StaticResource StandardButtonStyle}" Padding="10,6" Margin="6,0,0,0"
                            Click="ShortcutsToggle_Click" IsEnabled="{Binding CanInteract}"
                            ToolTip="Quick actions for selected rows" Background="#F0FFF4" BorderBrush="#16A34A" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Actions" FontSize="12" Foreground="#16A34A" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="ShortcutsPopup" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=ShortcutsToggleBtn}" AllowsTransparency="True">
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="4" Margin="0,4,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                            </Border.Effect>
                            <StackPanel Width="230">
                                <TextBlock Text="Quick Actions" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8" Margin="8,4,8,6"/>
                                <Button Click="ShortcutLinkingBasket_Click" Background="Transparent" BorderThickness="0" Padding="8,6" Cursor="Hand" HorizontalContentAlignment="Left">
                                    <DockPanel Width="210">
                                        <TextBlock Text="&#x1F517;" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                                        <Border Background="#F1F5F9" CornerRadius="3" Padding="4,1" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl+L" FontSize="9" Foreground="#64748B" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="Add to Linking Basket" FontSize="12" Foreground="#334155" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Button>
                                <Button Click="ShortcutOpenGrouped_Click" Background="Transparent" BorderThickness="0" Padding="8,6" Cursor="Hand" HorizontalContentAlignment="Left">
                                    <DockPanel Width="210">
                                        <TextBlock Text="G" FontSize="13" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                                        <Border Background="#F1F5F9" CornerRadius="3" Padding="4,1" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl+G" FontSize="9" Foreground="#64748B" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="Open Other Account" FontSize="12" Foreground="#334155" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Button>
                                <Rectangle Height="1" Fill="#F1F5F9" Margin="8,2"/>
                                <Button Click="ShortcutMarkDone_Click" Background="Transparent" BorderThickness="0" Padding="8,6" Cursor="Hand" HorizontalContentAlignment="Left">
                                    <DockPanel Width="210">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,8,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" DockPanel.Dock="Left"/>
                                        <Border Background="#F1F5F9" CornerRadius="3" Padding="4,1" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl+D" FontSize="9" Foreground="#64748B" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="Mark Done" FontSize="12" Foreground="#334155" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Button>
                                <Button Click="ShortcutComment_Click" Background="Transparent" BorderThickness="0" Padding="8,6" Cursor="Hand" HorizontalContentAlignment="Left">
                                    <DockPanel Width="210">
                                        <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,8,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" DockPanel.Dock="Left"/>
                                        <Border Background="#F1F5F9" CornerRadius="3" Padding="4,1" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl+K" FontSize="9" Foreground="#64748B" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="Set Comment" FontSize="12" Foreground="#334155" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Button>
                                <Button Click="ShortcutReminder_Click" Background="Transparent" BorderThickness="0" Padding="8,6" Cursor="Hand" HorizontalContentAlignment="Left">
                                    <DockPanel Width="210">
                                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#D97706" VerticalAlignment="Center" Margin="0,0,8,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display" DockPanel.Dock="Left"/>
                                        <Border Background="#F1F5F9" CornerRadius="3" Padding="4,1" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl+R" FontSize="9" Foreground="#64748B" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="Set Reminder" FontSize="12" Foreground="#334155" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Button>
                                <Rectangle Height="1" Fill="#F1F5F9" Margin="8,2"/>
                                <Button Click="ShortcutProcessDwings_Click" Background="Transparent" BorderThickness="0" Padding="8,6" Cursor="Hand" HorizontalContentAlignment="Left">
                                    <DockPanel Width="210">
                                        <TextBlock Text="&#x26A1;" FontSize="13" Foreground="#4169E1" VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left"/>
                                        <Border Background="#F1F5F9" CornerRadius="3" Padding="4,1" DockPanel.Dock="Right" VerticalAlignment="Center">
                                            <TextBlock Text="Ctrl+Shift+D" FontSize="9" Foreground="#64748B" FontFamily="Consolas"/>
                                        </Border>
                                        <TextBlock Text="Process DWINGS" FontSize="12" Foreground="#334155" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <!-- Status Indicators -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,0,0">
                    <Border Background="#FFF9E6" BorderBrush="#FFC107" BorderThickness="1" CornerRadius="6" Padding="8,5" Visibility="{Binding IsGlobalLockActive, Converter={StaticResource BooleanToVisibilityConverter}}" Effect="{StaticResource LightShadow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#FFC107" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Import in progress" VerticalAlignment="Center" Foreground="#795548" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- (Removed ToDo Mode Toggle and right-aligned selector) -->

            </Grid>
        </Border>

        <!-- Linking Basket Banner (visible only when items are in the basket) -->
        <Border x:Name="LinkingBasketBanner" Grid.Row="1" Visibility="Collapsed"
                Background="#E3F2FD" BorderBrush="#1976D2" BorderThickness="0,0,0,2" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔗" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>

                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock x:Name="LinkingBasketSummary" FontSize="12" FontWeight="SemiBold" Foreground="#0D47A1"
                               Text="Linking Basket: empty"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock x:Name="LinkingBasketPivotDetail" FontSize="11" Foreground="#1565C0" Margin="0,0,12,0"/>
                        <TextBlock x:Name="LinkingBasketRecvDetail" FontSize="11" Foreground="#1565C0"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock x:Name="LinkingBasketDelta" Grid.Column="2" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="12,0"/>

                <Button Grid.Column="3" Content="🔗 Link All" FontWeight="SemiBold" Padding="12,4"
                        x:Name="LinkBasketButton" Click="LinkBasket_Click"
                        Background="#1976D2" Foreground="White" BorderThickness="0"
                        Margin="4,0" Cursor="Hand" IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Column="4" Content="✕ Clear" Padding="8,4"
                        Click="ClearLinkingBasket_Click"
                        Background="Transparent" Foreground="#666" BorderThickness="0"
                        Margin="4,0" Cursor="Hand" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Main Content Area - Will contain dynamically added views -->
        <Grid Grid.Row="2">
            <!-- Loading indicator -->
            <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="99">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading data..." FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ProgressBar IsIndeterminate="True" Width="200" Height="10" />
                </StackPanel>
            </Border>
            <!-- Views Container - Horizontal stacking of multiple views -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ViewsPanel" Orientation="Vertical" Visibility="Collapsed" HorizontalAlignment="Stretch" />
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>