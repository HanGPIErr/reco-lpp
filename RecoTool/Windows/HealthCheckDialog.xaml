<Window x:Class="RecoTool.Windows.HealthCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Startup health check" Height="420" Width="640"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <DockPanel Margin="0">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BNPErrorBrush}" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Some startup checks failed"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock x:Name="SubtitleText"
                           Text="The application can still run, but the listed components may be unavailable."
                           Foreground="White" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource BNPSidebarBackground}" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ExitButton" Content="Exit" Width="100" Height="30"
                        Margin="0,0,8,0" Click="Exit_Click"/>
                <Button x:Name="ContinueButton" Content="Continue" Width="100" Height="30"
                        IsDefault="True" Click="Continue_Click"
                        Style="{StaticResource ModernPrimaryButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Failure list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
            <ItemsControl x:Name="FailuresList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BNPBorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="12,10" Margin="0,0,0,8"
                                Background="{StaticResource BNPSectionBackground}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{StaticResource BNPErrorBrush}"/>
                                <TextBlock Text="{Binding Message}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding ExceptionSummary}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource BNPTextSecondaryBrush}"
                                           Margin="0,6,0,0" TextWrapping="Wrap"
                                           Visibility="{Binding HasException, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
