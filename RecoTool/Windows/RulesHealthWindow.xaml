<Window x:Class="RecoTool.Windows.RulesHealthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:rules="clr-namespace:RecoTool.Services.Rules"
        mc:Ignorable="d"
        Title="Rules Health Center" Height="820" Width="1280"
        WindowStartupLocation="CenterOwner"
        Background="#F6F7F9">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
        </Style>
        <Style x:Key="Kpi" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="140"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🩺" FontSize="18" Foreground="White" Margin="0,0,8,0"/>
                <TextBlock Text="Rules Health Center" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" — Diagnose, simulate and validate rules before they run in production"
                           Foreground="#BDC3C7" Margin="10,0,0,0"/>
                <TextBlock Text="  |  Country: " Foreground="#95A5A6" Margin="16,0,0,0"/>
                <TextBlock x:Name="CountryText" Text="—" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Footer (progress + status) -->
        <Border DockPanel.Dock="Bottom" Background="#ECF0F1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="Ready" Foreground="#34495E"/>
                <ProgressBar Grid.Column="1" x:Name="StatusProgress" Height="12" Margin="12,0" Minimum="0" Maximum="1" Value="0"/>
                <Button Grid.Column="2" x:Name="CancelBtn" Content="Cancel" Click="Cancel_Click" IsEnabled="False"/>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs" Margin="8">
            <!-- ============================ TAB 1 : SIMULATOR ============================ -->
            <TabItem Header="🔬 Simulator">
                <DockPanel Margin="8">
                    <!-- Controls -->
                    <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Scope:"/>
                            <ComboBox x:Name="SimScopeCombo" Width="110" Margin="6,0,12,0" SelectedIndex="0">
                                <ComboBoxItem Content="Import" Tag="Import"/>
                                <ComboBoxItem Content="Edit" Tag="Edit"/>
                                <ComboBoxItem Content="Both" Tag="Both"/>
                            </ComboBox>
                            <Button Content="▶ Run Simulation" Click="RunSimulation_Click" Background="#27AE60" Foreground="White" FontWeight="SemiBold" Padding="14,6"/>
                            <Button Content="Export CSV" Click="ExportSimulation_Click" IsEnabled="False" x:Name="ExportSimBtn"/>
                            <Separator Margin="10,0"/>
                            <TextBlock Text="Filter rules:" Margin="6,0"/>
                            <TextBox x:Name="SimFilterBox" Width="220" TextChanged="SimFilter_TextChanged" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- KPI summary -->
                    <Border DockPanel.Dock="Top" Background="White" Padding="8" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource Kpi}" Background="#ECF0F1">
                                <StackPanel>
                                    <TextBlock Text="TOTAL ROWS" FontSize="10" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="SimTotalText" Text="—" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#E8F8F5">
                                <StackPanel>
                                    <TextBlock Text="MATCHED" FontSize="10" Foreground="#148F77"/>
                                    <TextBlock x:Name="SimMatchedText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#148F77"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#FDEDEC">
                                <StackPanel>
                                    <TextBlock Text="UNMATCHED" FontSize="10" Foreground="#C0392B"/>
                                    <TextBlock x:Name="SimUnmatchedText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#C0392B"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#FEF9E7">
                                <StackPanel>
                                    <TextBlock Text="DEAD RULES" FontSize="10" Foreground="#B7950B"/>
                                    <TextBlock x:Name="SimDeadText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#B7950B"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#EAF2F8">
                                <StackPanel>
                                    <TextBlock Text="ACTIVE RULES" FontSize="10" Foreground="#21618C"/>
                                    <TextBlock x:Name="SimActiveText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#21618C"/>
                                </StackPanel>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="18,0,0,0">
                                <TextBlock x:Name="SimRunAtText" Text="" Foreground="#7F8C8D" FontStyle="Italic"/>
                                <TextBlock x:Name="SimSummaryText" Text="Click 'Run Simulation' to evaluate all rules against the current dataset."
                                           TextWrapping="Wrap" MaxWidth="600" Foreground="#2C3E50"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Grid with results -->
                    <DataGrid x:Name="SimGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FAFBFC"
                              SelectionMode="Single"
                              SelectionChanged="SimGrid_SelectionChanged"
                              Background="White"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Status" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="6,2" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#27AE60"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDead}" Value="True">
                                                            <Setter Property="Background" Value="#E74C3C"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                            <Setter Property="Background" Value="#95A5A6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusBadge}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Rule ID" Binding="{Binding RuleId}" Width="260"/>
                            <DataGridTextColumn Header="Prio" Binding="{Binding Priority}" Width="60"/>
                            <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="70"/>
                            <DataGridTextColumn Header="Hits" Binding="{Binding HitCount}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="% Coverage" Binding="{Binding CoverageDisplay}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0,0,12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Last applied (log)" Binding="{Binding LastAppliedDisplay}" Width="140"/>
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="70"/>
                            <DataGridCheckBoxColumn Header="Auto" Binding="{Binding AutoApply}" Width="60"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ============================ TAB 2 : COVERAGE REPORT ============================ -->
            <TabItem Header="📊 Coverage Report">
                <DockPanel Margin="8">
                    <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Period (days):"/>
                            <ComboBox x:Name="CovPeriodCombo" Width="90" Margin="6,0,12,0" SelectedIndex="1">
                                <ComboBoxItem Content="7" Tag="7"/>
                                <ComboBoxItem Content="30" Tag="30"/>
                                <ComboBoxItem Content="90" Tag="90"/>
                            </ComboBox>
                            <TextBlock Text="Origin:"/>
                            <ComboBox x:Name="CovOriginCombo" Width="110" Margin="6,0,12,0" SelectedIndex="0">
                                <ComboBoxItem Content="All" Tag=""/>
                                <ComboBoxItem Content="import" Tag="import"/>
                                <ComboBoxItem Content="edit" Tag="edit"/>
                                <ComboBoxItem Content="run-now" Tag="run-now"/>
                            </ComboBox>
                            <TextBlock Text="Country filter:"/>
                            <TextBox x:Name="CovCountryBox" Width="90" Margin="6,0,12,0"/>
                            <Button Content="↻ Reload" Click="ReloadCoverage_Click" Background="#3498DB" Foreground="White" FontWeight="SemiBold"/>
                            <Button Content="Export CSV" Click="ExportCoverage_Click" x:Name="ExportCovBtn" IsEnabled="False"/>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="#FCF3CF" Padding="10" CornerRadius="4" Margin="0,0,0,8"
                            Visibility="Collapsed" x:Name="CovWarningsBox">
                        <StackPanel>
                            <TextBlock Text="⚠ Warnings" FontWeight="Bold" Foreground="#7D6608"/>
                            <ItemsControl x:Name="CovWarningsList" Margin="4,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#7D6608" TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="CovGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FAFBFC"
                              Background="White"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rule ID" Binding="{Binding RuleId}" Width="260"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="80"/>
                            <DataGridTextColumn Header="Import" Binding="{Binding Import}" Width="80"/>
                            <DataGridTextColumn Header="Edit" Binding="{Binding Edit}" Width="80"/>
                            <DataGridTextColumn Header="Run-Now" Binding="{Binding RunNow}" Width="90"/>
                            <DataGridTextColumn Header="Other" Binding="{Binding Other}" Width="80"/>
                            <DataGridTextColumn Header="Last applied" Binding="{Binding LastAppliedDisplay}" Width="150"/>
                            <DataGridTextColumn Header="Top countries" Binding="{Binding TopCountry}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ============================ TAB 3 : RULE TESTER ============================ -->
            <TabItem Header="🧪 Tester">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: context form -->
                    <Border Grid.Column="0" Background="White" Padding="12" CornerRadius="4" Margin="0,0,8,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Synthetic context" Style="{StaticResource SectionHeader}"/>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="▶ Evaluate" Click="RunTest_Click" Background="#8E44AD" Foreground="White" FontWeight="SemiBold"/>
                                <Button Content="Load from line..." Click="LoadContextFromLine_Click"/>
                                <Button Content="Reset" Click="ResetTesterForm_Click"/>
                            </StackPanel>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Scope" Margin="0,4"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TestScopeCombo" SelectedIndex="0" Margin="0,2">
                                        <ComboBoxItem Content="Import" Tag="Import"/>
                                        <ComboBoxItem Content="Edit" Tag="Edit"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Country ID" Margin="0,4"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TestCountryBox" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="IsPivot" Margin="0,4"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1" x:Name="TestIsPivotChk" Margin="0,6" IsThreeState="False"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="GuaranteeType" Margin="0,4"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="TestGuaranteeCombo" IsEditable="True" Margin="0,2">
                                        <ComboBoxItem Content="(null)"/>
                                        <ComboBoxItem Content="ISSUANCE"/>
                                        <ComboBoxItem Content="REISSUANCE"/>
                                        <ComboBoxItem Content="ADVISING"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="TransactionType" Margin="0,4"/>
                                    <ComboBox Grid.Row="4" Grid.Column="1" x:Name="TestTransactionCombo" IsEditable="True" Margin="0,2"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="HasDwingsLink" Margin="0,4"/>
                                    <CheckBox Grid.Row="5" Grid.Column="1" x:Name="TestHasDwingsChk" Margin="0,6" IsThreeState="True"/>
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="IsGrouped" Margin="0,4"/>
                                    <CheckBox Grid.Row="6" Grid.Column="1" x:Name="TestIsGroupedChk" Margin="0,6" IsThreeState="True"/>
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="IsAmountMatch" Margin="0,4"/>
                                    <CheckBox Grid.Row="7" Grid.Column="1" x:Name="TestIsAmountMatchChk" Margin="0,6" IsThreeState="True"/>
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Sign" Margin="0,4"/>
                                    <ComboBox Grid.Row="8" Grid.Column="1" x:Name="TestSignCombo" Margin="0,2" SelectedIndex="0">
                                        <ComboBoxItem Content="*" Tag=""/>
                                        <ComboBoxItem Content="C (Credit)" Tag="C"/>
                                        <ComboBoxItem Content="D (Debit)" Tag="D"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="MT Status" Margin="0,4"/>
                                    <ComboBox Grid.Row="9" Grid.Column="1" x:Name="TestMtStatusCombo" Margin="0,2" SelectedIndex="0">
                                        <ComboBoxItem Content="(null)" Tag=""/>
                                        <ComboBoxItem Content="ACKED" Tag="ACKED"/>
                                        <ComboBoxItem Content="NOT_ACKED" Tag="NOT_ACKED"/>
                                    </ComboBox>
                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="CommIdEmail" Margin="0,4"/>
                                    <CheckBox Grid.Row="10" Grid.Column="1" x:Name="TestCommIdEmailChk" Margin="0,6" IsThreeState="True"/>
                                    <TextBlock Grid.Row="11" Grid.Column="0" Text="BgiInitiated" Margin="0,4"/>
                                    <CheckBox Grid.Row="11" Grid.Column="1" x:Name="TestBgiInitiatedChk" Margin="0,6" IsThreeState="True"/>
                                    <TextBlock Grid.Row="12" Grid.Column="0" Text="PaymentReqStatus" Margin="0,4"/>
                                    <TextBox Grid.Row="12" Grid.Column="1" x:Name="TestPaymentStatusBox" Margin="0,2"/>
                                    <TextBlock Grid.Row="13" Grid.Column="0" Text="InvoiceStatus" Margin="0,4"/>
                                    <TextBox Grid.Row="13" Grid.Column="1" x:Name="TestInvoiceStatusBox" Margin="0,2"/>
                                    <TextBlock Grid.Row="14" Grid.Column="0" Text="IsFirstRequest" Margin="0,4"/>
                                    <CheckBox Grid.Row="14" Grid.Column="1" x:Name="TestIsFirstRequestChk" Margin="0,6" IsThreeState="True"/>
                                    <TextBlock Grid.Row="15" Grid.Column="0" Text="IsNewLine" Margin="0,4"/>
                                    <CheckBox Grid.Row="15" Grid.Column="1" x:Name="TestIsNewLineChk" Margin="0,6" IsThreeState="True"/>
                                    <TextBlock Grid.Row="16" Grid.Column="0" Text="DaysSinceReminder" Margin="0,4"/>
                                    <TextBox Grid.Row="16" Grid.Column="1" x:Name="TestDaysSinceReminderBox" Margin="0,2"/>
                                    <TextBlock Grid.Row="17" Grid.Column="0" Text="CurrentActionId" Margin="0,4"/>
                                    <TextBox Grid.Row="17" Grid.Column="1" x:Name="TestCurrentActionBox" Margin="0,2"/>
                                    <TextBlock Grid.Row="18" Grid.Column="0" Text="IsActionDone" Margin="0,4"/>
                                    <CheckBox Grid.Row="18" Grid.Column="1" x:Name="TestIsActionDoneChk" Margin="0,6" IsThreeState="True"/>
                                </Grid>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Right: result -->
                    <Border Grid.Column="1" Background="White" Padding="12" CornerRadius="4">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Evaluation result" Style="{StaticResource SectionHeader}"/>
                            <Border DockPanel.Dock="Top" x:Name="TestHeroBox" CornerRadius="4" Padding="10" Margin="0,0,0,8" Background="#ECF0F1">
                                <TextBlock x:Name="TestHeroText" Text="Fill the context and click Evaluate." FontSize="13" TextWrapping="Wrap"/>
                            </Border>
                            <DataGrid x:Name="TestGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      AlternatingRowBackground="#FAFBFC">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order" Binding="{Binding Order}" Width="50"/>
                                    <DataGridTextColumn Header="Rule ID" Binding="{Binding Rule.RuleId}" Width="260"/>
                                    <DataGridTextColumn Header="Prio" Binding="{Binding Rule.Priority}" Width="60"/>
                                    <DataGridTemplateColumn Header="Match" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="6,2" HorizontalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#27AE60"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                    <Setter Property="Background" Value="#E74C3C"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                    <Setter Property="Background" Value="#95A5A6"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Foreground="White" FontWeight="Bold" FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="MATCH"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMatch}" Value="False">
                                                                        <Setter Property="Text" Value="NO"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                                                        <Setter Property="Text" Value="OFF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Conditions (expected → actual)" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding Conditions}" Margin="4">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Margin="2" FontFamily="Consolas" FontSize="11">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#148F77"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMet}" Value="False">
                                                                                <Setter Property="Foreground" Value="#C0392B"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                <Run Text="{Binding Field, Mode=OneWay}" FontWeight="SemiBold"/>
                                                                <Run Text=": "/>
                                                                <Run Text="{Binding Expected, Mode=OneWay}"/>
                                                                <Run Text=" → "/>
                                                                <Run Text="{Binding Actual, Mode=OneWay}" FontStyle="Italic"/>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============================ TAB 4 : IMPACT PREVIEW ============================ -->
            <TabItem Header="🎯 Impact Preview">
                <DockPanel Margin="8">
                    <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Select a rule to preview its impact on the current dataset. The draft is compared to the current rule-set; you see which rows would start/stop matching without saving anything."
                                       TextWrapping="Wrap" Foreground="#566573" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Rule:"/>
                                <ComboBox x:Name="ImpactRuleCombo" Width="380" Margin="6,0,12,0" SelectionChanged="ImpactRuleCombo_SelectionChanged" DisplayMemberPath="RuleId"/>
                                <TextBlock Text="Scope:"/>
                                <ComboBox x:Name="ImpactScopeCombo" Width="110" Margin="6,0,12,0" SelectedIndex="0">
                                    <ComboBoxItem Content="Import" Tag="Import"/>
                                    <ComboBoxItem Content="Edit" Tag="Edit"/>
                                </ComboBox>
                                <Button Content="▶ Run Preview" Click="RunImpact_Click" Background="#D35400" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource Kpi}" Background="#ECF0F1">
                                <StackPanel>
                                    <TextBlock Text="BEFORE" FontSize="10" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="ImpactBeforeText" Text="—" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#FEF9E7">
                                <StackPanel>
                                    <TextBlock Text="AFTER" FontSize="10" Foreground="#7D6608"/>
                                    <TextBlock x:Name="ImpactAfterText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#7D6608"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#D5F5E3">
                                <StackPanel>
                                    <TextBlock Text="NEW MATCHES" FontSize="10" Foreground="#148F77"/>
                                    <TextBlock x:Name="ImpactNewText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#148F77"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#FADBD8">
                                <StackPanel>
                                    <TextBlock Text="STOPPED MATCHING" FontSize="10" Foreground="#C0392B"/>
                                    <TextBlock x:Name="ImpactLostText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#C0392B"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#D6EAF8">
                                <StackPanel>
                                    <TextBlock Text="CHANGED OUTPUTS" FontSize="10" Foreground="#21618C"/>
                                    <TextBlock x:Name="ImpactChangedText" Text="—" FontSize="20" FontWeight="Bold" Foreground="#21618C"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock DockPanel.Dock="Top" Text="Newly matching rows" FontWeight="SemiBold" Foreground="#148F77" Margin="0,0,0,4"/>
                            <ListBox x:Name="ImpactNewList" FontFamily="Consolas" FontSize="11"/>
                        </DockPanel>
                        <DockPanel Grid.Column="1" Margin="4,0">
                            <TextBlock DockPanel.Dock="Top" Text="Stopped matching rows" FontWeight="SemiBold" Foreground="#C0392B" Margin="0,0,0,4"/>
                            <ListBox x:Name="ImpactLostList" FontFamily="Consolas" FontSize="11"/>
                        </DockPanel>
                        <DockPanel Grid.Column="2" Margin="4,0,0,0">
                            <TextBlock DockPanel.Dock="Top" Text="Changed outputs (still matching)" FontWeight="SemiBold" Foreground="#21618C" Margin="0,0,0,4"/>
                            <ListBox x:Name="ImpactChangedList" FontFamily="Consolas" FontSize="11"/>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ============================ TAB 5 : PENDING PROPOSALS ============================ -->
            <TabItem Header="📋 Proposals">
                <DockPanel Margin="8">
                    <!-- Controls -->
                    <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Status:"/>
                            <ComboBox x:Name="PropStatusCombo" Width="140" Margin="6,0,12,0" SelectedIndex="0" SelectionChanged="ReloadProposals_Click">
                                <ComboBoxItem Content="Pending" Tag="Pending"/>
                                <ComboBoxItem Content="Accepted" Tag="Accepted"/>
                                <ComboBoxItem Content="Rejected" Tag="Rejected"/>
                                <ComboBoxItem Content="Stale" Tag="Stale"/>
                                <ComboBoxItem Content="(all)" Tag=""/>
                            </ComboBox>
                            <Button Content="↻ Reload" Click="ReloadProposals_Click" Background="#3498DB" Foreground="White" FontWeight="SemiBold"/>
                            <Separator Margin="10,0"/>
                            <Button Content="✓ Accept selected" Click="AcceptProposals_Click" Background="#27AE60" Foreground="White" FontWeight="SemiBold"/>
                            <Button Content="✗ Reject selected" Click="RejectProposals_Click" Background="#E74C3C" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PropStatusText" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="#566573"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid -->
                    <DataGrid x:Name="PropGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Extended"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FAFBFC"
                              Background="White"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Status" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="6,2" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F39C12"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Accepted">
                                                            <Setter Property="Background" Value="#27AE60"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                            <Setter Property="Background" Value="#E74C3C"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Applied">
                                                            <Setter Property="Background" Value="#21618C"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Stale">
                                                            <Setter Property="Background" Value="#95A5A6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusBadge}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProposalId}" Width="60"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="130"/>
                            <DataGridTextColumn Header="Rule" Binding="{Binding RuleId}" Width="220"/>
                            <DataGridTextColumn Header="Reco" Binding="{Binding RecoId}" Width="220" FontFamily="Consolas" FontSize="11"/>
                            <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="110"/>
                            <DataGridTextColumn Header="Old → New" Binding="{Binding Summary}" Width="*"/>
                            <DataGridTextColumn Header="Decided by" Binding="{Binding DecidedBy}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ============================ TAB 6 : AMBRE IMPORT SIMULATION ============================ -->
            <TabItem Header="🔬 Simulate AMBRE">
                <DockPanel Margin="8">
                    <!-- Controls -->
                    <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Load the same AMBRE Excel file you would normally import, then evaluate rules against every row (scope = Import). No data is written to the DB — this is a pure what-if run."
                                       TextWrapping="Wrap" Foreground="#566573" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="📂 Pick AMBRE file…" Click="PickAmbreFile_Click" Background="#2980B9" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AmbreFilePathText" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#566573" Text="(no file selected)"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="RunSimButton" Content="▶ Run simulation" Click="RunAmbreSim_Click" Background="#27AE60" Foreground="White" FontWeight="SemiBold" IsEnabled="False"/>
                                <Button Content="⎘ Export CSV" Click="ExportAmbreSim_Click" Margin="6,0,0,0" Background="#7F8C8D" Foreground="White" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AmbreSimStatusText" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#566573"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- KPIs -->
                    <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource Kpi}" Background="#ECF0F1">
                                <StackPanel>
                                    <TextBlock Text="TOTAL ROWS" FontSize="10" Foreground="#7F8C8D"/>
                                    <TextBlock x:Name="AmbreSimTotal" Text="—" FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#E8F6F3">
                                <StackPanel>
                                    <TextBlock Text="MATCHED" FontSize="10" Foreground="#148F77"/>
                                    <TextBlock x:Name="AmbreSimMatched" Text="—" FontSize="20" FontWeight="Bold" Foreground="#148F77"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#FEF5E7">
                                <StackPanel>
                                    <TextBlock Text="WOULD MUTATE" FontSize="10" Foreground="#B9770E"/>
                                    <TextBlock x:Name="AmbreSimMutate" Text="—" FontSize="20" FontWeight="Bold" Foreground="#B9770E"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#FADBD8">
                                <StackPanel>
                                    <TextBlock Text="NEW ROWS" FontSize="10" Foreground="#943126"/>
                                    <TextBlock x:Name="AmbreSimNew" Text="—" FontSize="20" FontWeight="Bold" Foreground="#943126"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Kpi}" Background="#EBF5FB">
                                <StackPanel>
                                    <TextBlock Text="UNIQUE RULES" FontSize="10" Foreground="#21618C"/>
                                    <TextBlock x:Name="AmbreSimUniqueRules" Text="—" FontSize="20" FontWeight="Bold" Foreground="#21618C"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Filter bar -->
                    <Border DockPanel.Dock="Top" Background="White" Padding="8" CornerRadius="4" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="AmbreSimFilterMutate" Content="Show only rows that would mutate" Margin="0,0,14,0" Checked="AmbreSimFilter_Changed" Unchecked="AmbreSimFilter_Changed"/>
                            <CheckBox x:Name="AmbreSimFilterMatched" Content="Show only matched rows" Margin="0,0,14,0" Checked="AmbreSimFilter_Changed" Unchecked="AmbreSimFilter_Changed"/>
                            <CheckBox x:Name="AmbreSimFilterNew" Content="Show only new rows (not yet in DB)" Margin="0,0,14,0" Checked="AmbreSimFilter_Changed" Unchecked="AmbreSimFilter_Changed"/>
                            <TextBlock Text="Rule:" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <ComboBox x:Name="AmbreSimRuleFilter" Width="220" SelectionChanged="AmbreSimFilter_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Grid -->
                    <DataGrid x:Name="AmbreSimGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#FAFBFC"
                              Background="White"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Δ" Width="40" ToolTipService.ToolTip="Would mutate the reconciliation">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value=""/>
                                                    <Setter Property="Foreground" Value="#95A5A6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WouldMutate}" Value="True">
                                                            <Setter Property="Text" Value="●"/>
                                                            <Setter Property="Foreground" Value="#B9770E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="New?" Width="50" ToolTipService.ToolTip="Would INSERT (row not yet in DB)">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value=""/>
                                                    <Setter Property="Foreground" Value="#95A5A6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExistsInDb}" Value="False">
                                                            <Setter Property="Text" Value="NEW"/>
                                                            <Setter Property="Foreground" Value="#943126"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding ReconciliationId}" Width="220" FontFamily="Consolas" FontSize="11"/>
                            <DataGridTextColumn Header="Account" Binding="{Binding Account}" Width="100"/>
                            <DataGridTextColumn Header="CCY" Binding="{Binding Currency}" Width="55"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding SignedAmount, StringFormat='#,0.00'}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Rule matched" Binding="{Binding MatchedRuleId}" Width="220"/>
                            <DataGridTextColumn Header="Proposed changes" Binding="{Binding ChangesSummary}" Width="*"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding UserMessage}" Width="200"/>
                            <DataGridTextColumn Header="Raw label" Binding="{Binding RawLabel}" Width="200" FontFamily="Consolas" FontSize="10"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
