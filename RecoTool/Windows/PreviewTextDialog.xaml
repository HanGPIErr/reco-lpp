<Window x:Class="RecoTool.Windows.PreviewTextDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E">
    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="#2D2D30" Padding="12,8">
            <DockPanel>
                <TextBlock x:Name="TitleBlock" FontWeight="SemiBold" FontSize="14" Foreground="#DCDCDC"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="FormatBadge" Margin="10,0,0,0" Padding="6,2" FontSize="11"
                           Foreground="#9CDCFE" Background="#3C3C3C" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom" Background="#2D2D30" Padding="8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="CopyButton" Width="90" Height="28" Content="📋 Copy" Click="Copy_Click"
                            Margin="0,0,8,0" Background="#3C3C3C" Foreground="#DCDCDC" BorderBrush="#555"/>
                    <Button Width="90" Height="28" Content="Close" IsDefault="True" Click="Close_Click"
                            Background="#3C3C3C" Foreground="#DCDCDC" BorderBrush="#555"/>
                </StackPanel>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" FontSize="11" Foreground="#888" Margin="4,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- Content area: XML viewer (RichTextBox) or plain text (TextBox) -->
        <Grid Margin="0">
            <!-- XML formatted view (dark theme with syntax highlighting) -->
            <RichTextBox x:Name="XmlRichTextBox"
                         IsReadOnly="True"
                         Background="#1E1E1E"
                         Foreground="#D4D4D4"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12.5"
                         Padding="12,8"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Visibility="Collapsed"/>

            <!-- Plain text fallback -->
            <TextBox x:Name="ContentTextBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     BorderThickness="0"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     FontFamily="Consolas"
                     FontSize="12.5"
                     Padding="12,8"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Visibility="Collapsed"/>
        </Grid>
    </DockPanel>
</Window>
