<Window x:Class="RecoTool.Windows.SpiritGeneSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpiritGene Transaction Search"
        Width="1350" Height="720"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search Parameters -->
        <GroupBox Grid.Row="0" Header="Search Parameters" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Date From:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <DatePicker Grid.Row="0" Grid.Column="1" x:Name="DateFromPicker" Margin="0,0,0,6" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Date To:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <DatePicker Grid.Row="0" Grid.Column="4" x:Name="DateToPicker" Margin="0,0,0,6" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount Min:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="AmountMinBox" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="Amount Max:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox Grid.Row="1" Grid.Column="4" x:Name="AmountMaxBox" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="BIC:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="BicComboBox" Margin="0,0,0,6"
                          DisplayMemberPath="DisplayText" SelectedValuePath="Bic" IsEditable="False"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Direction:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <ComboBox Grid.Row="2" Grid.Column="4" x:Name="DirectionCombo" Margin="0,0,0,6" SelectedIndex="0">
                    <ComboBoxItem Content="Received (R)" Tag="R"/>
                    <ComboBoxItem Content="Sent (A)" Tag="A"/>
                </ComboBox>

                <Button Grid.Row="3" Grid.Column="4" x:Name="SearchButton" Content="🔍 Search"
                        Click="SearchButton_Click" HorizontalAlignment="Right"
                        Padding="16,6" Background="#1976D2" Foreground="White" FontWeight="SemiBold"
                        Cursor="Hand" Margin="0,4,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </GroupBox>

        <!-- Status -->
        <TextBlock Grid.Row="1" x:Name="StatusText" Text="" Margin="0,0,0,4" FontStyle="Italic" Foreground="#666"/>

        <!-- Split view -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="380"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="370" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Results DataGrid -->
            <DataGrid Grid.Column="0" x:Name="ResultsGrid"
                      SelectionChanged="ResultsGrid_SelectionChanged"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding CTypeOpe}" Width="60"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding DRgltOpe}" Width="90"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding DisplayAmount}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Ordering IBAN" Binding="{Binding IIbanDo}" Width="170"/>
                    <DataGridTextColumn Header="Ord. BIC" Binding="{Binding IBicDo}" Width="90"/>
                    <DataGridTextColumn Header="Benef. IBAN" Binding="{Binding IIbanBen}" Width="170"/>
                    <DataGridTextColumn Header="Ben. BIC" Binding="{Binding IBicBen}" Width="90"/>
                    <DataGridTextColumn Header="End-to-End ID" Binding="{Binding LEndToEndId}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD" Cursor="SizeWE"/>

            <!-- Right: Detail panel -->
            <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="10,8,10,4">
                        <TextBlock x:Name="DetailTitleText" FontSize="12" FontWeight="Bold"
                                   Foreground="#1565C0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="DetailSubText" FontSize="10" Foreground="#666"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Separator Grid.Row="1" Margin="6,0"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="8,4">
                        <StackPanel>
                            <TextBlock x:Name="DetailLoadingText"
                                       Text="Select a transaction to see details."
                                       Foreground="#999" FontStyle="Italic" Margin="2,8"/>
                            <ItemsControl x:Name="DetailFieldsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="145"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}"
                                                       FontWeight="SemiBold" Foreground="#424242"
                                                       FontSize="11" VerticalAlignment="Top"
                                                       Margin="0,0,8,0" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                       Foreground="#212121" FontSize="11"
                                                       TextWrapping="Wrap" VerticalAlignment="Top"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <Button Grid.Row="3" x:Name="DetailCopyButton" Content="📋 Copy"
                            Click="DetailCopyButton_Click"
                            HorizontalAlignment="Right" Margin="8,4"
                            Padding="10,4" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="CountText" Text="" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#666"/>
            <Button Content="Close" Click="CloseButton_Click" Padding="12,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
