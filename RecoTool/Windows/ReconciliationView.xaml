<UserControl x:Class="RecoTool.Windows.ReconciliationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RecoTool.Windows"
             xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             x:Name="Root"
             mc:Ignorable="d po" 
             d:DesignHeight="600" d:DesignWidth="900"
             Focusable="True">
    <UserControl.InputBindings>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static local:ReconciliationView.FocusQuickSearchCommand}"/>
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{x:Static local:ReconciliationView.ShortcutLinkingBasketCommand}"/>
        <KeyBinding Key="G" Modifiers="Ctrl" Command="{x:Static local:ReconciliationView.ShortcutOpenGroupedCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{x:Static local:ReconciliationView.ShortcutMarkDoneCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl+Shift" Command="{x:Static local:ReconciliationView.ShortcutProcessDwingsCommand}"/>
        <KeyBinding Key="K" Modifiers="Ctrl" Command="{x:Static local:ReconciliationView.ShortcutSetCommentCommand}"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{x:Static local:ReconciliationView.ShortcutSetReminderCommand}"/>
    </UserControl.InputBindings>
    <UserControl.Resources>
        <!-- Resources extracted to dedicated ResourceDictionaries for maintainability.
             Physical layout: Windows/ReconciliationView/Resources/*.xaml
               • SharedResources.xaml    : UserFieldItemTemplate + converter instances
               • GridHeaderStyles.xaml   : header brushes + per-source header Styles
               • GridRowStyles.xaml      : row/cell styles + selection/grid-line brushes -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RecoTool;component/Windows/ReconciliationView/Resources/SharedResources.xaml"/>
                <ResourceDictionary Source="/RecoTool;component/Windows/ReconciliationView/Resources/GridHeaderStyles.xaml"/>
                <ResourceDictionary Source="/RecoTool;component/Windows/ReconciliationView/Resources/GridRowStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource BNPBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Multi-user session warning banner removed — presence is shown via row-level badges and header avatars -->

        <!-- Compact Modern Header with Integrated KPIs -->
        <Border x:Name="HeaderBorder" Grid.Row="1" Background="White" Padding="12,8" Effect="{StaticResource StandardShadow}" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- View Info + KPIs Integrated -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- View Title Card -->
                    <Border Background="{DynamicResource BNPMainGreenBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="White" CornerRadius="6" Width="32" Height="32" Margin="0,0,10,0">
                                <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource BNPMainGreenBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TitleText" Text="Default View" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="White" Opacity="0.9" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                    <TextBlock x:Name="AccountInfoText" Text="Account: All | Status: All" Foreground="White" Opacity="0.9" FontSize="10" MaxWidth="350" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="&#xE910;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="White" Opacity="0.9" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                    <TextBlock x:Name="AccountTypeText" Text="" Foreground="White" Opacity="0.9" FontSize="10" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Enhanced KPI Cards with Labels -->
                    <StackPanel Orientation="Horizontal" Height="55">
                        <!-- Total Rows -->
                        <Border Background="#F4F7FE" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#E0E6F7" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE179;" FontFamily="Segoe MDL2 Assets" Foreground="#3B82F6" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="Total" FontSize="11" Foreground="#64748B" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiTotalCountText" Margin="5,5,0,0" Text="0" FontSize="13" FontWeight="Bold" Foreground="#0F172A"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <!-- Total Amount -->
                        <Border Background="#F8FAFC" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💰"  Foreground="#2563EB" FontSize="13" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="Amount" FontSize="11" Foreground="#64748B" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiTotalAmountText" Margin="5,5,0,0" Text="0.00" FontSize="13" FontWeight="Bold" Foreground="#0F172A"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Separator -->
                        <Rectangle Width="2" Height="40" Fill="#E2E8F0" Margin="4,0"/>

                        <!-- Not Linked -->
                        <Border x:Name="KpiNotLinkedBorder" Background="#FFEBEE" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#EF9A9A" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="KpiFilter_Click" Tag="NotLinked"
                                ToolTip="Not linked with DWINGS">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" Foreground="#EF4444" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="Not Linked" FontSize="11" Foreground="#7F1D1D" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiNotLinkedCountText" Text="0" Margin="5,5,0,0" FontSize="13" FontWeight="Bold" Foreground="#C62828"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Not Grouped -->
                        <Border x:Name="KpiNotGroupedBorder" Background="#FFF3E0" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#FFCC80" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="KpiFilter_Click" Tag="NotGrouped"
                                ToolTip="Not grouped across accounts">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Foreground="#FF9800" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="Not Grouped" FontSize="11" Foreground="#E65100" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiNotGroupedCountText" Text="0" Margin="5,5,0,0" FontSize="13" FontWeight="Bold" Foreground="#E65100"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- To Review -->
                        <Border x:Name="KpiToReviewBorder" Background="#FFF7ED" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#FFEDD5" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="KpiFilter_Click" Tag="ToReview">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#FB923C" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="To Review" FontSize="11" Foreground="#9A3412" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiToReviewCountText" Text="0" Margin="5,5,0,0" FontSize="13" FontWeight="Bold" Foreground="#7C2D12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- To Remind -->
                        <Border x:Name="KpiToRemindBorder" Background="#FFF3E0" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#FFCC80" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="KpiFilter_Click" Tag="ToRemind"
                                ToolTip="Active reminders (today or past due)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" Foreground="#FF9800" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="To Remind" FontSize="11" Foreground="#E65100" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiToRemindCountText" Text="0" Margin="5,5,0,0" FontSize="13" FontWeight="Bold" Foreground="#E65100"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Reviewed -->
                        <Border x:Name="KpiReviewedBorder" Background="#ECFDF5" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#D1FAE5" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="KpiFilter_Click" Tag="Reviewed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#10B981" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="Reviewed" FontSize="11" Foreground="#065F46" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiReviewedCountText" Text="0" Margin="5,5,0,0" FontSize="13" FontWeight="Bold" Foreground="#064E3B"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Has Differences -->
                        <Border x:Name="KpiHasDifferencesBorder" Background="#FFFDE7" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#FFF59D" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="KpiFilter_Click" Tag="HasDifferences"
                                ToolTip="Has discrepancy in amounts">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#FBC02D" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="Differences" FontSize="11" Foreground="#F57F17" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiDiscrepancyCountText" Text="0" Margin="5,5,0,0" FontSize="13" FontWeight="Bold" Foreground="#F57F17"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Matched -->
                        <Border x:Name="KpiMatchedBorder" Background="#E8F5E9" CornerRadius="6" Padding="10,6" Margin="0,0,4,0" BorderBrush="#A5D6A7" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="KpiFilter_Click" Tag="Matched"
                                ToolTip="Balanced and grouped">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#4CAF50" FontSize="12" VerticalAlignment="Center" Margin="0,20,0,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                <StackPanel>
                                    <TextBlock Text="Matched" FontSize="11" Foreground="#2E7D32" Margin="0,0,0,1"/>
                                    <TextBlock x:Name="KpiMatchedCountText" Text="0" Margin="5,5,0,0" FontSize="13" FontWeight="Bold" Foreground="#2E7D32"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Active Users Panel (real-time presence) -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding ActiveUsers, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Width="28" Height="28" Background="#7C3AED" Margin="2,0"
                                    ToolTip="{Binding DisplayName}" Cursor="Help">
                                <TextBlock Text="{Binding Initials}" Foreground="White"
                                           FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Action Buttons Group -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">


                    <!-- View Management Group (collapsed - not needed currently) -->
                    <Border Background="#E3F2FD" CornerRadius="6" Padding="8,6" BorderBrush="#2196F3" BorderThickness="1.5" Margin="0,0,12,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="📋 VIEW" FontSize="9" FontWeight="Bold" Foreground="#1976D2" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="LoadViewButton" Click="LoadView_Click" Style="{StaticResource StandardButtonStyle}" Background="Transparent" BorderThickness="0" Padding="8,6" ToolTip="Load saved view (columns + filters + sort)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Load" Foreground="#2196F3" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Rectangle Width="1" Height="20" Fill="#90CAF9" Margin="4,0"/>
                                <Button x:Name="SaveViewButton" Click="SaveView_Click" Style="{StaticResource StandardButtonStyle}" Background="Transparent" BorderThickness="0" Padding="8,6" ToolTip="Save current view (columns + filters + sort)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#1976D2" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Save" Foreground="#1976D2" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Filter Management Group (collapsed – accessible via Filters expander) -->
                    <Border Background="#FFF3E0" CornerRadius="6" Padding="8,6" BorderBrush="#FF9800" BorderThickness="1.5" Margin="0,0,8,0" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="🔍 FILTER" FontSize="9" FontWeight="Bold" Foreground="#F57C00" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="LoadFilterButton" Click="LoadFilter_Click" Style="{StaticResource StandardButtonStyle}" Background="Transparent" BorderThickness="0" Padding="6,4" ToolTip="Load saved filter (criteria only)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,4,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Load" Foreground="#FF9800" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Rectangle Width="1" Height="18" Fill="#FFB74D" Margin="3,0"/>
                                <Button x:Name="SaveFilterButton" Click="SaveFilter_Click" Style="{StaticResource StandardButtonStyle}" Background="Transparent" BorderThickness="0" Padding="6,4" ToolTip="Save current filter (criteria only)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#F57C00" VerticalAlignment="Center" Margin="0,0,4,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Save" Foreground="#F57C00" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Rectangle Width="1" Height="18" Fill="#FFB74D" Margin="3,0"/>
                                <Button x:Name="ReapplyFilterButton" Click="ReapplyFilter_Click" Style="{StaticResource StandardButtonStyle}" Background="Transparent" BorderThickness="0" Padding="6,4" ToolTip="Reapply current filter">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#FF9800" VerticalAlignment="Center" Margin="0,0,4,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Reapply" Foreground="#FF9800" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Rectangle Width="1" Height="18" Fill="#FFB74D" Margin="3,0"/>
                                <Button x:Name="ResetFilterButton" Click="ResetFilter_Click" Style="{StaticResource StandardButtonStyle}" Background="Transparent" BorderThickness="0" Padding="6,4" ToolTip="Clear all filters">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#9E9E9E" VerticalAlignment="Center" Margin="0,0,4,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Reset" Foreground="#9E9E9E" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Actions Group -->
                    <Border Background="#F8F9FA" CornerRadius="6" Padding="6,4" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="1" Height="20" Fill="#DEE2E6" Margin="4,0"/>
                            <Button x:Name="ExportButton" Click="Export_Click" Style="{StaticResource StandardButtonStyle}" Background="Transparent" BorderThickness="0" Padding="8,6" ToolTip="Export">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#00BCD4" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                    <TextBlock Text="Export" Foreground="#00BCD4" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Activity Log Button -->
                    <Button x:Name="ActivityLogButton" Click="ToggleActivityLog_Click"
                            Style="{StaticResource StandardButtonStyle}" Background="#EDE9FE" BorderBrush="#A78BFA" BorderThickness="1" Padding="8,6" Margin="0,0,8,0"
                            ToolTip="Recent activity (who changed what)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#7C3AED" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Activity" Foreground="#7C3AED" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Import History Button (snapshot-based "what changed since last import") -->
                    <Button x:Name="ImportHistoryButton" Click="ImportHistoryButton_Click"
                            Style="{StaticResource StandardButtonStyle}" Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1" Padding="8,6" Margin="0,0,8,0"
                            ToolTip="What changed since the last AMBRE imports">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Imports" Foreground="#2563EB" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!--
                        Import History Popup. Opened by ImportHistoryButton_Click in Activity.cs;
                        left column lists recent runs, right column shows the impact report for
                        the selected run (field-level stats + alerts + clickable "show rows" buttons).
                    -->
                    <Popup x:Name="ImportHistoryPopup" PlacementTarget="{Binding ElementName=ImportHistoryButton}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8"
                                Width="760" MaxHeight="520" Margin="0,4,0,0"
                                Effect="{StaticResource StandardShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0" Background="#EFF6FF" CornerRadius="8,8,0,0" Padding="12,8">
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2563EB" VerticalAlignment="Center" Margin="0,0,6,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                            <TextBlock Text="Import History" FontSize="14" FontWeight="Bold" Foreground="#1E3A8A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ImportHistoryHint" DockPanel.Dock="Right"
                                                   Text="Pick a run on the left to see its impact."
                                                   FontSize="11" Foreground="#64748B"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                </Border>

                                <!-- Body: left = runs list, right = impact details -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Runs list -->
                                    <ListBox x:Name="ImportHistoryRunsList"
                                             Grid.Column="0"
                                             BorderThickness="0,0,1,0"
                                             BorderBrush="#E2E8F0"
                                             Background="Transparent"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             SelectionChanged="ImportHistoryRun_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Kind}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="12"/>
                                                            <TextBlock Text=" · " Foreground="#CBD5E1"/>
                                                            <TextBlock Text="{Binding StartedUtc, StringFormat=yyyy-MM-dd HH:mm}" Foreground="#64748B" FontSize="11"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding TriggeredBy}" Foreground="#94A3B8" FontSize="10" Margin="0,2,0,0"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Border Background="#DCFCE7" CornerRadius="3" Padding="4,1" Margin="0,0,3,0">
                                                                <TextBlock Text="{Binding NewCount, StringFormat=+{0}}" Foreground="#166534" FontSize="10" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Border Background="#FEF3C7" CornerRadius="3" Padding="4,1" Margin="0,0,3,0">
                                                                <TextBlock Text="{Binding UpdatedCount, StringFormat=~{0}}" Foreground="#92400E" FontSize="10" FontWeight="SemiBold"/>
                                                            </Border>
                                                            <Border Background="#FEE2E2" CornerRadius="3" Padding="4,1">
                                                                <TextBlock Text="{Binding ArchivedCount, StringFormat=-{0}}" Foreground="#991B1B" FontSize="10" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Impact details -->
                                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="14,10">
                                        <StackPanel x:Name="ImportHistoryDetailsPanel">
                                            <TextBlock x:Name="ImportHistoryPlaceholder"
                                                       Text="No run selected."
                                                       Foreground="#94A3B8" FontStyle="Italic" FontSize="12"/>

                                            <!-- Alerts -->
                                            <TextBlock x:Name="ImportHistoryAlertsHeader"
                                                       Text="Alerts" FontWeight="Bold" Foreground="#1E293B"
                                                       FontSize="13" Margin="0,0,0,4" Visibility="Collapsed"/>
                                            <ItemsControl x:Name="ImportHistoryAlerts" Margin="0,0,0,10">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="4"
                                                                Padding="8,4" Margin="0,2,0,0"
                                                                Cursor="Hand" MouseLeftButtonUp="ImportHistoryImpactRow_Click"
                                                                Tag="{Binding RowIds}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#B45309" VerticalAlignment="Center" Margin="0,0,6,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="#78350F" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" · " Foreground="#D97706"/>
                                                                <TextBlock Text="{Binding Count}" Foreground="#92400E" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" rows" Foreground="#92400E" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Material field changes -->
                                            <TextBlock x:Name="ImportHistoryFieldsHeader"
                                                       Text="Fields changed" FontWeight="Bold" Foreground="#1E293B"
                                                       FontSize="13" Margin="0,0,0,4" Visibility="Collapsed"/>
                                            <ItemsControl x:Name="ImportHistoryFields">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"
                                                                Padding="8,4" Margin="0,2,0,0"
                                                                Cursor="Hand" MouseLeftButtonUp="ImportHistoryImpactRow_Click"
                                                                Tag="{Binding RowIds}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding FieldName}" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Count}" Foreground="#475569" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                    <TextBlock Text=" rows" Foreground="#64748B" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="  Show" Foreground="#2563EB" FontSize="11" TextDecorations="Underline" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>
                    </Popup>

                    <!-- Mention Notification Badge (bell icon) -->
                    <Border x:Name="MentionBadgeButton" Background="#F0F9FF" CornerRadius="6" BorderBrush="#38BDF8" BorderThickness="1"
                            Padding="8,6" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonUp="MentionBadge_Click"
                            ToolTip="You have been @mentioned in comments">
                        <Grid>
                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#0284C7"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            <!-- Red badge with count -->
                            <Border x:Name="MentionBadge" Visibility="Collapsed"
                                    Background="#EF4444" CornerRadius="8" MinWidth="16" Height="16"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,-6,-6,0"
                                    Padding="3,0">
                                <TextBlock x:Name="MentionBadgeText" Text="0" Foreground="White" FontSize="10"
                                           FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <!-- Mention Popup (dropdown from badge) -->
                    <Popup x:Name="MentionPopup" PlacementTarget="{Binding ElementName=MentionBadgeButton}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8"
                                Width="400" MaxHeight="400" Margin="0,4,0,0"
                                Effect="{StaticResource StandardShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#F0F9FF" CornerRadius="8,8,0,0" Padding="12,8">
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#0284C7" VerticalAlignment="Center" Margin="0,0,6,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                            <TextBlock Text="Your Mentions" FontSize="14" FontWeight="Bold" Foreground="#0284C7" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="MarkAllMentionsRead" DockPanel.Dock="Right" Text="Mark all read" FontSize="11" Foreground="#64748B"
                                                   Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   MouseLeftButtonUp="MarkAllMentionsRead_Click" TextDecorations="Underline"/>
                                    </DockPanel>
                                </Border>
                                <ListBox x:Name="MentionListBox" Grid.Row="1" BorderThickness="0" Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="MentionRowBorder" Padding="10,8" Cursor="Hand" MouseLeftButtonUp="MentionItem_MouseLeftButtonUp"
                                                    BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- New indicator dot -->
                                                    <Ellipse x:Name="NewDot" Grid.Column="0" Width="8" Height="8" Fill="#3B82F6"
                                                             Margin="0,0,8,0" VerticalAlignment="Top" Visibility="Collapsed"/>
                                                    <Grid Grid.Column="1">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding MentionedBy}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="12"/>
                                                            <TextBlock Text=" mentioned you" Foreground="#64748B" FontSize="12"/>
                                                            <TextBlock Text=" · " Foreground="#CBD5E1"/>
                                                            <TextBlock Text="{Binding TimeAgo}" Foreground="#94A3B8" FontSize="11"/>
                                                            <TextBlock Text=" · " Foreground="#CBD5E1"/>
                                                            <TextBlock Text="{Binding RecordRef}" Foreground="#3B82F6" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="1" Text="{Binding CommentSnippet}" Foreground="#475569" FontSize="11"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsNew}" Value="True">
                                                    <Setter TargetName="MentionRowBorder" Property="Background" Value="#EFF6FF"/>
                                                    <Setter TargetName="NewDot" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Popup>

                    <!-- Close Button -->
                    <Button x:Name="CloseViewButton" Click="CloseViewButton_Click" Style="{StaticResource StandardButtonStyle}" Background="#FFEBEE" BorderBrush="#EF5350" BorderThickness="1" Padding="10,6" ToolTip="Close View">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#D32F2F" VerticalAlignment="Center" Margin="0,0,5,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Close" Foreground="#D32F2F" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content with Filters and Data -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" x:Name="FiltersRow"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filters Section -->
            <Expander Grid.Row="0" IsExpanded="False" x:Name="FiltersExpander" Background="{DynamicResource BNPSectionBackground}" BorderBrush="{DynamicResource BNPBorderBrush}" BorderThickness="1" Margin="0,0,0,6">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource BNPMainGreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Filters" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BNPMainGreenBrush}"/>
                    </StackPanel>
                </Expander.Header>
                <Border Background="{DynamicResource BNPSectionBackground}" Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Ambre Filters -->
                        <GroupBox Grid.Column="0" Margin="0,0,10,0" BorderBrush="{DynamicResource BNPBorderBrush}" BorderThickness="1" Background="#FAFAFA">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource BNPMainGreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Ambre Filters" FontWeight="SemiBold" Foreground="{DynamicResource BNPMainGreenBrush}"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Reconciliation #:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Margin="5,0,0,0" Text="{Binding VM.FilterReconciliationNum, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Label:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Margin="5,0,0,0" Text="{Binding VM.FilterRawLabel, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Event #:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Margin="5,0,0,0" Text="{Binding VM.FilterEventNum, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Category:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Margin="5,0,0,0" x:Name="FilterCategoryCombo"
                                              IsEditable="True" IsTextSearchEnabled="True"
                                              Text="{Binding VM.FilterCategory, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Operation Date:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <DatePicker SelectedDate="{Binding VM.FilterOperationDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5,0" BorderThickness="0" Background="Transparent"/>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Deleted Date:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <DatePicker SelectedDate="{Binding VM.FilterDeletedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5,0" BorderThickness="0" Background="Transparent"/>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Currency:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <ComboBox x:Name="CurrencyComboBox" Margin="5,0" BorderThickness="0" Background="Transparent" Style="{StaticResource ModernComboBoxStyle}"
                                                  ItemsSource="{Binding CurrencyOptions}"
                                                  SelectedItem="{Binding VM.FilterCurrency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Amount:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Margin="5,0,0,0" Text="{Binding VM.FilterAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>


                                <!-- New lines toggle -->
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="New lines:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <CheckBox Grid.Column="1" Margin="5,0,0,0" IsChecked="{Binding VM.FilterNewLines, Mode=TwoWay}" Content="Created today"/>
                                </Grid>

                                <!-- Potential Duplicates (moved here from User Filters) -->
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Potential Duplicates:" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="PotentialDuplicatesCheckBox" Grid.Column="1" Margin="5,0,0,0"
                                              Content="Show only potential duplicates"
                                              ToolTip="Show only rows where the same combination of Event_Num, Reconciliation_Num, and Account_ID occurs more than once in Ambre (DupCount > 1)."
                                              IsChecked="{Binding VM.FilterPotentialDuplicates, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- DWings Filters -->
                        <GroupBox Grid.Column="1" Margin="0,0,10,0" BorderBrush="{DynamicResource BNPBorderBrush}" BorderThickness="1" Background="#FAFAFA">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource BNPMainGreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="DWings Filters" FontWeight="SemiBold" Foreground="{DynamicResource BNPMainGreenBrush}"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="DWINGS Ref:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <TextBox Margin="5" BorderThickness="0" Background="Transparent" Text="{Binding VM.FilterDwRef, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </Grid>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Guarantee Type:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <ComboBox x:Name="TypeComboBox" Margin="5,0" BorderThickness="0" Background="Transparent" Style="{StaticResource ModernComboBoxStyle}"
                                                  ItemsSource="{Binding GuaranteeTypeOptions}"
                                                  SelectedItem="{Binding VM.FilterGuaranteeType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Transaction Type:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <ComboBox x:Name="TransactionTypeComboBox" Margin="5,0" BorderThickness="0" Background="Transparent" Style="{StaticResource ModernComboBoxStyle}"
                                                  ItemsSource="{Binding VM.TransactionTypeOptions}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding VM.FilterTransactionTypeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        </ComboBox>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Client:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <TextBox Margin="5" BorderThickness="0" Background="Transparent" Text="{Binding VM.FilterClient, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Guarantee Status:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="GuaranteeStatusComboBox" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernComboBoxStyle}"
                                              ItemsSource="{Binding GuaranteeStatusOptions}"
                                              SelectedItem="{Binding VM.FilterGuaranteeStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <!-- Unmatched toggle -->
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Unmatched:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <CheckBox Grid.Column="1" Margin="5,0,0,0" IsChecked="{Binding VM.FilterUnmatched, Mode=TwoWay}" Content="No invoice linked"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- User Filters -->
                        <GroupBox Grid.Column="2" Margin="0,0,0,0" BorderBrush="{DynamicResource BNPBorderBrush}" BorderThickness="1" Background="#FAFAFA">
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource BNPMainGreenBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="User Filters" FontWeight="SemiBold" Foreground="{DynamicResource BNPMainGreenBrush}"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <!-- Category filter removed per request -->

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Action:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ActionComboBox" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernComboBoxStyle}"
                                              SelectedValuePath="USR_ID"
                                              ItemTemplate="{StaticResource UserFieldItemTemplate}"
                                              SelectedValue="{Binding VM.FilterActionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBox.ItemsSource>
                                            <MultiBinding Converter="{StaticResource UserFieldOptionsConverter}" ConverterParameter="Action">
                                                <Binding Path="DataContext.VM.FilterAccountId" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="DataContext.AllUserFields" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="DataContext.CurrentCountryObject" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </ComboBox.ItemsSource>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="KPI:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="KPIComboBox" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernComboBoxStyle}"
                                              SelectedValuePath="USR_ID"
                                              ItemTemplate="{StaticResource UserFieldItemTemplate}"
                                              SelectedValue="{Binding VM.FilterKpiId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBox.ItemsSource>
                                            <MultiBinding Converter="{StaticResource UserFieldOptionsConverter}" ConverterParameter="KPI">
                                                <Binding Path="DataContext.VM.FilterAccountId" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="DataContext.AllUserFields" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="DataContext.CurrentCountryObject" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </ComboBox.ItemsSource>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Incident Type:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="IncidentTypeComboBox" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernComboBoxStyle}"
                                              SelectedValuePath="USR_ID"
                                              ItemTemplate="{StaticResource UserFieldItemTemplate}"
                                              SelectedValue="{Binding VM.FilterIncidentTypeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBox.ItemsSource>
                                            <MultiBinding Converter="{StaticResource UserFieldOptionsConverter}" ConverterParameter="Incident Type">
                                                <Binding Path="DataContext.VM.FilterAccountId" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="DataContext.AllUserFields" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                <Binding Path="DataContext.CurrentCountryObject" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </ComboBox.ItemsSource>
                                    </ComboBox>
                                </Grid>

                                <!-- Action Done filter -->
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Action Done:" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernComboBoxStyle}"
                                              SelectedValue="{Binding VM.FilterActionDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="{x:Null}">All</ComboBoxItem>
                                        <ComboBoxItem Tag="False">Pending</ComboBoxItem>
                                        <ComboBoxItem Tag="True">Done</ComboBoxItem>
                                    </ComboBox>
                                </Grid>

                                <!-- Action Date (precise) -->
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Action Date:" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <DatePicker SelectedDate="{Binding VM.FilterActionDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5,0" BorderThickness="0" Background="Transparent"/>
                                    </Border>
                                </Grid>

                                

                                <!-- Assignee filter -->
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Assignee:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="AssigneeComboBox" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernComboBoxStyle}"
                                              ItemsSource="{Binding AssigneeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding VM.FilterAssigneeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <!-- optional: no static items; list includes empty entry -->
                                    </ComboBox>
                                </Grid>

                                <!-- Last Reviewed filter -->
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Last Reviewed:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="LastReviewedComboBox" Grid.Column="1" Margin="5,0,0,0" Style="{StaticResource ModernComboBoxStyle}"
                                              SelectedValue="{Binding VM.FilterLastReviewed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Content">
                                        <ComboBoxItem Content="All" IsSelected="True"/>
                                        <ComboBoxItem Content="Never"/>
                                        <ComboBoxItem Content="Today"/>
                                        <ComboBoxItem Content="1week"/>
                                        <ComboBoxItem Content="1month"/>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Comments:" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    <Border Grid.Column="1" Background="White" CornerRadius="4" BorderBrush="#DDDDDD" BorderThickness="1">
                                        <TextBox Margin="5"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             TextWrapping="NoWrap"
                                             AcceptsReturn="False"
                                             Text="{Binding VM.FilterComments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Border>
                                </Grid>

                            </StackPanel>
                        </GroupBox>

                    </Grid>
                </Border>
            </Expander>

            <!-- Quick Search Bar (Ctrl+F) -->
            <Border x:Name="QuickSearchBar" Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="8,5" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search icon -->
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                               Foreground="#64748B" VerticalAlignment="Center" Margin="4,0,8,0"
                               UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>

                    <!-- Search TextBox -->
                    <TextBox x:Name="QuickSearchTextBox" Grid.Column="1" 
                             FontSize="13" Padding="6,4" BorderThickness="1" BorderBrush="#E2E8F0"
                             Background="White" VerticalContentAlignment="Center"
                             KeyDown="QuickSearchBox_KeyDown">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Tag" Value="Search all fields... (Enter to search, Esc to clear)"/>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Search all fields... (Enter to search, Esc to clear)" 
                                                                   Foreground="#94A3B8" FontSize="12" Margin="8,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource BNPMainGreenBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Result count badge -->
                    <TextBlock x:Name="QuickSearchResultBadge" Grid.Column="2" 
                               Visibility="Collapsed" FontSize="11" FontWeight="SemiBold"
                               Foreground="#3B82F6" VerticalAlignment="Center" Margin="8,0,0,0"/>

                    <!-- Search button -->
                    <Button Grid.Column="3" Click="QuickSearchButton_Click" 
                            ToolTip="Search (Enter)" Cursor="Hand" Margin="6,0,0,0"
                            Background="{DynamicResource BNPMainGreenBrush}" Foreground="White"
                            BorderThickness="0" Padding="10,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"
                                                   UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Search" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Clear button -->
                    <Button x:Name="QuickSearchClearButton" Grid.Column="4" Click="QuickSearchClear_Click"
                            Visibility="Collapsed" ToolTip="Clear search (Esc)" Cursor="Hand" Margin="4,0,0,0"
                            Background="Transparent" BorderThickness="0" Padding="6,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#FEE2E2" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                               Foreground="#DC2626" VerticalAlignment="Center"
                                               UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Data Grid Section -->
            <!-- PERF: DropShadowEffect removed. It forced the entire grid (50+ columns × visible rows)
                 to render into an offscreen bitmap with blur on every scroll frame.
                 A lighter visual shadow is achieved via an extra 1px bottom border + subtle padding. -->
            <Border Grid.Row="2" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="19*"/>
                        <ColumnDefinition Width="879*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Activity Log Overlay Panel (right side drawer) -->
                    <Border x:Name="ActivityLogPanel" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="2"
                            Panel.ZIndex="900" Visibility="Collapsed"
                            HorizontalAlignment="Right" Width="380"
                            Background="White" BorderBrush="#A78BFA" BorderThickness="1,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Header -->
                            <Border Grid.Row="0" Background="#EDE9FE" Padding="12,10">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#7C3AED" VerticalAlignment="Center" Margin="0,0,8,0" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="Recent Activity" FontSize="15" FontWeight="Bold" Foreground="#5B21B6"/>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Click="ActivityLogClose_Click" Padding="4" ToolTip="Close">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#7C3AED" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- Activity List -->
                            <ListBox x:Name="ActivityLogListBox" Grid.Row="1" BorderThickness="0" Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Cursor="Hand" MouseLeftButtonUp="ActivityLogItem_MouseLeftButtonUp"
                                                BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- User avatar circle -->
                                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="#EDE9FE" Margin="0,0,10,0" VerticalAlignment="Top">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#7C3AED"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="True" TextOptions.TextFormattingMode="Display"/>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding User}" FontWeight="SemiBold" Foreground="#1E293B" FontSize="12"/>
                                                        <TextBlock Text=" · " Foreground="#CBD5E1"/>
                                                        <TextBlock Text="{Binding Operation}" Foreground="#7C3AED" FontSize="11" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <TextBlock Foreground="#64748B" FontSize="11" Margin="0,2,0,0">
                                                        <Run Text="{Binding RecordRef, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding AccountSide, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Label}" Foreground="#94A3B8" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding TimeAgo}" Foreground="#A78BFA" FontSize="10" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Loading Overlay -->
                    <Border Grid.RowSpan="3" Background="#80FFFFFF" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="1000" Grid.ColumnSpan="2">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="LoadingRotation"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="LoadingRotation"
                                                   Storyboard.TargetProperty="Angle"
                                                   From="0" To="360" Duration="0:0:2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                            <TextBlock Text="Loading data..." FontSize="16" FontWeight="SemiBold" 
                          Foreground="{DynamicResource BNPMainGreenBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Results Grid — Syncfusion SfDataGrid for high performance -->
                    <!-- PERF: TextFormattingMode=Display + TextRenderingMode=Aliased + UseLayoutRounding + SnapsToDevicePixels
                         significantly reduce per-frame text layout cost during scrolling. -->
                    <syncfusion:SfDataGrid x:Name="ResultsDataGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              AllowEditing="True"
                              EditTrigger="OnDoubleTap"
                              AllowSorting="True"
                              AllowResizingColumns="True"
                              AllowDraggingColumns="True"
                              ShowRowHeader="False"
                              AddNewRowPosition="None"
                              ItemsSource="{Binding VM.ViewData, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              FrozenColumnCount="6"
                              SelectionMode="Extended"
                              SelectionUnit="Row"
                              NavigationMode="Cell"
                              FontFamily="Segoe UI"
                              FontSize="12"
                              RowHeight="30"
                              HeaderRowHeight="36"
                              GridLinesVisibility="Horizontal"
                              HeaderLinesVisibility="Horizontal"
                              RowSelectionBrush="{StaticResource GridSelectionBrush}"
                              SelectionForegroundBrush="{StaticResource GridSelectionFg}"
                              HeaderStyle="{StaticResource DefaultGridHeaderStyle}"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True"
                              TextOptions.TextFormattingMode="Display"
                              TextOptions.TextRenderingMode="ClearType"
                              TextOptions.TextHintingMode="Fixed"
                              RenderOptions.BitmapScalingMode="LowQuality"
                              RenderOptions.ClearTypeHint="Enabled"
                              ScrollViewer.CanContentScroll="True"
                              EnableDataVirtualization="True"
                              ColumnSizer="None"
                              AllowResizingHiddenColumns="False"
                              AllowTriStateSorting="False"
                              LiveDataUpdateMode="AllowDataShaping"
                              Loaded="ResultsDataGrid_Loaded"
                              SelectionChanged="ResultsDataGrid_SelectionChanged"
                              CurrentCellBeginEdit="ResultsDataGrid_CurrentCellBeginEdit"
                              CurrentCellEndEdit="ResultsDataGrid_CurrentCellEndEdit"
                              CurrentCellValueChanged="ResultsDataGrid_CurrentCellValueChanged"
                              CellTapped="ResultsDataGrid_CellTapped"
                              MouseDoubleClick="ResultsDataGrid_MouseDoubleClick"
                              QueryColumnDragging="ResultsDataGrid_QueryColumnDragging"
                              Grid.ColumnSpan="2" Grid.RowSpan="2">
                        <syncfusion:SfDataGrid.SortColumnDescriptions>
                            <syncfusion:SortColumnDescription ColumnName="Operation_Date" SortDirection="Ascending"/>
                        </syncfusion:SfDataGrid.SortColumnDescriptions>
                        <!-- Row context menu (populated dynamically) -->
                        <syncfusion:SfDataGrid.RecordContextMenu>
                            <ContextMenu Opened="DataGridRow_ContextMenuOpening">
                                <MenuItem Header="🔗 Add to Linking Basket" Tag="LinkingBasket" FontWeight="SemiBold"/>
                                <Separator/>
                                <MenuItem Header="Set Action" Tag="Action"/>
                                <MenuItem Header="Set KPI" Tag="KPI"/>
                                <MenuItem Header="Set Incident Type" Tag="Incident Type"/>
                                <MenuItem Header="Set Risky" Tag="Risky"/>
                            </ContextMenu>
                        </syncfusion:SfDataGrid.RecordContextMenu>
                        <syncfusion:SfDataGrid.Columns>
                            <!-- Status Indicator Column (Frozen) -->
                            <syncfusion:GridTemplateColumn HeaderText="" Width="150" AllowEditing="False" AllowResizing="False" AllowDragging="False">
                                <syncfusion:GridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#F1F5F9" CornerRadius="4" Padding="6,3" HorizontalAlignment="Center">
                                            <TextBlock Text="⚑ Status" FontSize="11" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" Cursor="Help"
                                                       ToolTip="Status Legend:&#x0a;🔴 Red = Not linked with DWINGS&#x0a;🟠 Orange = Not grouped&#x0a;🟡 Yellow = Small discrepancy&#x0a;🟤 Amber = Large discrepancy (>100)&#x0a;🟢 Green = Balanced &amp; grouped&#x0a;&#x0a;[N] = New entry  [U] = Updated entry&#x0a;[G] = Grouped across accounts"/>
                                        </Border>
                                    </DataTemplate>
                                </syncfusion:GridTemplateColumn.HeaderTemplate>
                                <syncfusion:GridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- PERF: Replaced nested Grid(4 cols) + double-Ellipse glow with a flat
                                             StackPanel + single Ellipse. Saves ~4 FrameworkElements per row
                                             and one ellipse render pass per frame during scroll. -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- Presence avatar (other user viewing this row) -->
                                            <Border CornerRadius="10" Width="20" Height="20" Margin="0,0,4,0"
                                                    Background="#7C3AED" Visibility="{Binding PresenceVisibility}"
                                                    ToolTip="{Binding PresenceUserName}">
                                                <TextBlock Text="{Binding PresenceInitials}" Foreground="White"
                                                           FontSize="8" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <!-- New/Updated pill badge — pre-calculated brushes -->
                                            <Border CornerRadius="8" Padding="6,2" Margin="0,0,5,0"
                                                    Visibility="{Binding HasStatusIndicatorVisibility}"
                                                    Background="{Binding StatusBadgeBgBrush}">
                                                <TextBlock Text="{Binding StatusIndicator}"
                                                           Foreground="{Binding StatusBadgeFgBrush}"
                                                           FontWeight="Bold" FontSize="9"/>
                                            </Border>
                                            <!-- Status color dot (single ellipse, no glow halo) -->
                                            <Ellipse Width="12" Height="12" Fill="{Binding StatusColorBrush}"
                                                     VerticalAlignment="Center"
                                                     ToolTip="{Binding StatusTooltip}"/>
                                            <!-- Group indicator pill -->
                                            <Border Background="#DCFCE7" CornerRadius="8" Padding="5,2" Margin="5,0,0,0"
                                                    Cursor="Hand"
                                                    ToolTip="Click to open related entries across accounts"
                                                    Visibility="{Binding IsMatchedAcrossAccountsVisibility}"
                                                    MouseLeftButtonUp="MatchedIndicator_MouseLeftButtonUp">
                                                <TextBlock Text="G" Foreground="#166534" FontWeight="Bold" FontSize="9"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </syncfusion:GridTemplateColumn.CellTemplate>
                            </syncfusion:GridTemplateColumn>
                            <!-- Account side column (P/R) - SIMPLIFIED: removed DataTriggers for performance -->
                            <!--<syncfusion:GridTextColumn HeaderText="Account" Binding="{Binding AccountSide}" Width="60" AllowEditing="False" HeaderStyle="{StaticResource AmbreHeaderStyle}">
                                <syncfusion:GridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="ToolTip" Value="P = Pivot, R = Receivable"/>
                                    </Style>
                                </syncfusion:GridTextColumn.ElementStyle>
                            </syncfusion:GridTextColumn>-->
                            <syncfusion:GridTextColumn HeaderText="DW Guarantee ID" AllowDragging="False" MappingName="DWINGS_GuaranteeID" Width="170" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Event Num" MappingName="Event_Num" Width="100" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource AmbreHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Pivot Transaction Codes" MappingName="Pivot_TransactionCodesFromLabel" Width="150" AllowEditing="False" HeaderStyle="{StaticResource AmbreHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Category" MappingName="CategoryLabel" Width="140" AllowEditing="False" HeaderStyle="{StaticResource AmbreHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Raw Label" MappingName="RawLabel" Width="200" AllowEditing="False" HeaderStyle="{StaticResource AmbreHeaderStyle}"/>
                            <!-- Newly added DWINGS invoice columns near the beginning -->
                            <syncfusion:GridTextColumn HeaderText="Receiver" MappingName="I_RECEIVER_NAME" Width="180" AllowEditing="False" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="MT Status" MappingName="I_MT_STATUS" Width="120" AllowEditing="False" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <!-- HasEmail: COMM_ID_EMAIL flag from DWINGS invoice (used for rules) -->
                            <syncfusion:GridCheckBoxColumn HeaderText="HasEmail" Width="80" MappingName="HasEmail" AllowEditing="False" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="MT Error message" MappingName="I_ERROR_MESSAGE" Width="220" AllowEditing="False" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Amount" MappingName="LocalSignedAmount" Width="150" AllowEditing="False" HeaderStyle="{StaticResource AmbreHeaderStyle}" DisplayBinding="{Binding LocalSignedAmount, StringFormat={}{0:N2}}" TextAlignment="Right">
                                <syncfusion:GridTextColumn.CellStyle>
                                    <Style TargetType="syncfusion:GridCell">
                                        <Setter Property="Foreground" Value="{Binding LocalSignedAmountFgBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </syncfusion:GridTextColumn.CellStyle>
                            </syncfusion:GridTextColumn>
                            <syncfusion:GridTextColumn HeaderText="Operation Date" MappingName="Operation_Date" DisplayBinding="{Binding Operation_Date, StringFormat={}{0:dd/MM/yyyy}}" Width="110" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource AmbreHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Reconciliation Num" MappingName="Reconciliation_Num" Width="130" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Reconciliation Origin Num" MappingName="ReconciliationOrigin_Num" Width="150" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Matched date" MappingName="DeleteDate" DisplayBinding="{Binding DeleteDate, StringFormat=dd/MM/yyyy}" Width="150" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <!-- DWINGS link fields (from T_Reconciliation) -->
                            <syncfusion:GridTextColumn HeaderText="DW Invoice ID (BGI)" MappingName="DWINGS_InvoiceID" Width="150" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="DW Commission (BGPMT)" MappingName="DWINGS_BGPMT" Width="170" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Official Ref" MappingName="G_OFFICIALREF" Width="160" AllowEditing="False" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Amount in original CCY" MappingName="SignedAmount" Width="150" AllowEditing="False" HeaderStyle="{StaticResource AmbreHeaderStyle}" DisplayBinding="{Binding SignedAmount, StringFormat={}{0:N2}}" TextAlignment="Right">
                                <syncfusion:GridTextColumn.CellStyle>
                                    <Style TargetType="syncfusion:GridCell">
                                        <Setter Property="Foreground" Value="{Binding SignedAmountFgBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </syncfusion:GridTextColumn.CellStyle>
                            </syncfusion:GridTextColumn>
                            <syncfusion:GridTextColumn HeaderText="CCY" MappingName="CCY" Width="60" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource AmbreHeaderStyle}"/>

                            <!-- Missing Amount: conditional formatting via pre-calculated brushes on DTO.
                                 Native GridTextColumn — no Border wrapper instantiated per row. -->
                            <syncfusion:GridTextColumn HeaderText="Missing Amount" Width="140" MappingName="MissingAmount" AllowEditing="False"
                                                       DisplayBinding="{Binding MissingAmount, StringFormat={}{0:N2}}" TextAlignment="Right">
                                <syncfusion:GridTextColumn.CellStyle>
                                    <Style TargetType="syncfusion:GridCell">
                                        <Setter Property="Background" Value="{Binding MissingAmountBgBrush}"/>
                                        <Setter Property="Foreground" Value="{Binding MissingAmountFgBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="ToolTip" Value="Missing Amount&#x0a;• Positive: Waiting for more payments&#x0a;• Negative: Overpayment&#x0a;• Zero: Balanced"/>
                                    </Style>
                                </syncfusion:GridTextColumn.CellStyle>
                            </syncfusion:GridTextColumn>

                            <!-- Counterpart Info: static blue pill, native GridTextColumn. -->
                            <syncfusion:GridTextColumn HeaderText="Counterpart" Width="150" MappingName="CounterpartDisplay" AllowEditing="False"
                                                       DisplayBinding="{Binding CounterpartDisplay}" TextAlignment="Center">
                                <syncfusion:GridTextColumn.CellStyle>
                                    <Style TargetType="syncfusion:GridCell">
                                        <Setter Property="Background" Value="#EFF6FF"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="ToolTip" Value="{Binding CounterpartTooltip}"/>
                                    </Style>
                                </syncfusion:GridTextColumn.CellStyle>
                            </syncfusion:GridTextColumn>

                            <syncfusion:GridTextColumn HeaderText="Value Date" MappingName="Value_Date" DisplayBinding="{Binding Value_Date, StringFormat={}{0:dd/MM/yyyy}}" Width="110" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource AmbreHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Guarantee Type" MappingName="GuaranteeTypeDisplay"  Width="130" AllowEditing="False" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>
                            <!-- Colonnes T_Reconciliation (données combinées à plat dans ReconciliationViewData) -->

                            <!-- Action: native GridTextColumn with CellStyle bound to pre-calculated ActionBgBrush.
                                 Editable via popup (see ShowUserFieldEditPopup). PERF: 3-5x faster than GridTemplateColumn+Border wrapper. -->
                            <syncfusion:GridTextColumn HeaderText="Action" Width="120" MappingName="Action"
                                                       DisplayBinding="{Binding ActionDisplayName}" TextAlignment="Center" AllowEditing="False"
                                                       HeaderStyle="{StaticResource UserHeaderStyle}">
                                <syncfusion:GridTextColumn.CellStyle>
                                    <Style TargetType="syncfusion:GridCell">
                                        <Setter Property="Background" Value="{Binding ActionBgBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </syncfusion:GridTextColumn.CellStyle>
                            </syncfusion:GridTextColumn>
                            <!-- Action Status (Pending/Done). Native GridTextColumn + CellStyle for background.
                                 Editable via two-button popup (ShowActionStatusEditPopup). -->
                            <syncfusion:GridTextColumn HeaderText="Action Status" Width="120" MappingName="ActionStatus"
                                                       DisplayBinding="{Binding ActionStatusText}" TextAlignment="Center" AllowEditing="False"
                                                       HeaderStyle="{StaticResource UserHeaderStyle}">
                                <syncfusion:GridTextColumn.CellStyle>
                                    <Style TargetType="syncfusion:GridCell">
                                        <Setter Property="Background" Value="{Binding ActionStatusBgBrush}"/>
                                        <Setter Property="Foreground" Value="{Binding ActionStatusFgBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="10"/>
                                    </Style>
                                </syncfusion:GridTextColumn.CellStyle>
                            </syncfusion:GridTextColumn>
                            <!-- Action Date -->
                            <syncfusion:GridTextColumn HeaderText="Action Date" Width="160" MappingName="ActionDate" HeaderStyle="{StaticResource UserHeaderStyle}" DisplayBinding="{Binding ActionDate, StringFormat={}{0:dd/MM/yyyy}}" TextAlignment="Center" AllowEditing="False"/>
                            <!-- Assignee: displays user name, binds ID -->
                            <syncfusion:GridTextColumn HeaderText="Assignee" Width="140" MappingName="Assignee" HeaderStyle="{StaticResource UserHeaderStyle}" DisplayBinding="{Binding AssigneeDisplayName}" TextAlignment="Center" AllowEditing="False"/>

                            <!-- PERF: Click is routed via CellTapped (see ResultsDataGrid_CellTapped) instead of
                                 PreviewMouseLeftButtonUp on the DataTemplate root. Event subscription used to re-attach
                                 on every row recycle — now a single handler on the grid. -->
                            <syncfusion:GridTemplateColumn HeaderText="Comments" Width="220" MappingName="LastComment" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}">
                                <syncfusion:GridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel ToolTip="{Binding Comments}" LastChildFill="True" Cursor="Hand">
                                            <Grid DockPanel.Dock="Left" Margin="0,0,4,0"
                                                  Visibility="{Binding CommentBadgeVisibility}">
                                                <TextBlock Text="💬" FontSize="12" VerticalAlignment="Center"/>
                                                <Border Background="#3B82F6" CornerRadius="7" MinWidth="14" Height="14"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,-3,-6,0" Padding="3,0">
                                                    <TextBlock Text="{Binding CommentCountText}"
                                                               Foreground="White" FontSize="8" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding LastComment}" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" FontSize="11.5" Foreground="#374151"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </syncfusion:GridTemplateColumn.CellTemplate>
                            </syncfusion:GridTemplateColumn>
                            <!-- Internal Invoice Ref: editable text, native GridTextColumn with CellStyle for group color. -->
                            <syncfusion:GridTextColumn HeaderText="Internal Invoice Ref" MappingName="InternalInvoiceReference" Width="140"
                                                       HeaderStyle="{StaticResource UserHeaderStyle}" AllowEditing="True">
                                <syncfusion:GridTextColumn.CellStyle>
                                    <Style TargetType="syncfusion:GridCell">
                                        <Setter Property="Background" Value="{Binding InvoiceGroupBrush}"/>
                                        <Setter Property="ToolTip" Value="{Binding InternalInvoiceReference}"/>
                                    </Style>
                                </syncfusion:GridTextColumn.CellStyle>
                            </syncfusion:GridTextColumn>

                            <!-- MbawData: click routed via CellTapped. MappingName added so CellTapped can identify the column. -->
                            <syncfusion:GridTemplateColumn HeaderText="Mbaw Data" Width="250" MappingName="MbawData" AllowEditing="False" HeaderStyle="{StaticResource UserHeaderStyle}">
                                <syncfusion:GridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel ToolTip="{Binding MbawData}" LastChildFill="True" Cursor="Hand">
                                            <TextBlock DockPanel.Dock="Left" Text="🔍" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Visibility="{Binding MbawIconVisibility}"/>
                                            <TextBlock Text="{Binding MbawData}" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" FontSize="11"
                                                       Foreground="{Binding MbawForegroundBrush}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </syncfusion:GridTemplateColumn.CellTemplate>
                            </syncfusion:GridTemplateColumn>

                            <!-- First Claim Date -->
                            <syncfusion:GridTextColumn HeaderText="First Claim Date" Width="160" MappingName="FirstClaimDate" HeaderStyle="{StaticResource UserHeaderStyle}" DisplayBinding="{Binding FirstClaimDate, StringFormat={}{0:dd/MM/yyyy}}" TextAlignment="Center" AllowEditing="False"/>

                            <!-- Last Claim Date -->
                            <syncfusion:GridTextColumn HeaderText="Last Claim Date" Width="160" MappingName="LastClaimDate" HeaderStyle="{StaticResource UserHeaderStyle}" DisplayBinding="{Binding LastClaimDate, StringFormat={}{0:dd/MM/yyyy}}" TextAlignment="Center" AllowEditing="False"/>

                            <!-- PERF: native GridCheckBoxColumn — 3× lighter than GridTemplateColumn+CheckBox.
                                 Saves the entire CheckBox control-template tree on every row recycle.
                                 Edit commit is handled by ResultsDataGrid_CurrentCellEndEdit. -->
                            <syncfusion:GridCheckBoxColumn HeaderText="To Remind" Width="80" MappingName="ToRemind" HeaderStyle="{StaticResource UserHeaderStyle}"/>

                            <!-- Remind Date -->
                            <syncfusion:GridTextColumn HeaderText="Remind Date" Width="150" MappingName="ToRemindDate" HeaderStyle="{StaticResource UserHeaderStyle}" DisplayBinding="{Binding ToRemindDate, StringFormat={}{0:dd/MM/yyyy}}" TextAlignment="Center" AllowEditing="False"/>
                            <syncfusion:GridCheckBoxColumn HeaderText="ACK" Width="60" MappingName="ACK" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Swift Code" MappingName="SwiftCode" Width="100" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Payment Reference" MappingName="PaymentReference" Width="130" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="User" Width="120" AllowEditing="False" MappingName="ModifiedByDisplayName" TextAlignment="Center" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <!-- KPI: editable via tap popup (see ShowUserFieldEditPopup). PERF: native GridTextColumn. -->
                            <syncfusion:GridTextColumn HeaderText="KPI" Width="160" MappingName="KPI"
                                                       DisplayBinding="{Binding KpiDisplayName}" TextAlignment="Center" AllowEditing="False"
                                                       HeaderStyle="{StaticResource UserHeaderStyle}"/>

                            <!-- Incident Type: editable via tap popup. PERF: native GridTextColumn. -->
                            <syncfusion:GridTextColumn HeaderText="Incident Type" Width="180" MappingName="IncidentType"
                                                       DisplayBinding="{Binding IncidentTypeDisplayName}" TextAlignment="Center" AllowEditing="False"
                                                       HeaderStyle="{StaticResource UserHeaderStyle}"/>

                            <!-- Incident Number: editable text field -->
                            <syncfusion:GridTextColumn HeaderText="Incident Number" MappingName="IncNumber" Width="140" AllowEditing="True" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <syncfusion:GridCheckBoxColumn HeaderText="Risky Item" Width="100" MappingName="RiskyItem" HeaderStyle="{StaticResource UserHeaderStyle}"/>
                            <!-- Reason Non Risky: editable via tap popup. PERF: native GridTextColumn. -->
                            <syncfusion:GridTextColumn HeaderText="Reason Non Risky" Width="180" MappingName="ReasonNonRisky"
                                                       DisplayBinding="{Binding ReasonNonRiskyDisplayName}" TextAlignment="Center" AllowEditing="False"
                                                       HeaderStyle="{StaticResource UserHeaderStyle}"/>

                            <syncfusion:GridTextColumn HeaderText="DW Currency" MappingName="GUARANTEE_CURRENCY" Width="80" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="DW Amount" MappingName="GUARANTEE_AMOUNT" DisplayBinding="{Binding GUARANTEE_AMOUNT, StringFormat={}{0:N2}}" Width="120" AllowEditing="False" TextAlignment="Right" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>

                            <!-- DWINGS Guarantee extended fields -->
                            <syncfusion:GridTextColumn HeaderText="NatureOfDeal" MappingName="G_NATUREOFDEAL" Width="110" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Issue Date" MappingName="G_ISSUEDATE" Width="110" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="PartyID" MappingName="G_PARTY_ID" Width="110" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="PartyName" MappingName="G_NAME1" Width="160" AllowEditing="False" HeaderStyle="{StaticResource DWGuaranteeHeaderStyle}"/>

                            <!-- DWINGS Invoice extended fields -->
                            <syncfusion:GridTextColumn HeaderText="Payment Request Status" MappingName="I_T_PAYMENT_REQUEST_STATUS" Width="150" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Req Amount" MappingName="I_REQUESTED_INVOICE_AMOUNT" Width="130" AllowEditing="False" TextAlignment="Right" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Cur" MappingName="I_BILLING_CURRENCY" Width="70" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="StartDate" MappingName="I_START_DATE" Width="110" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="EndDate" MappingName="I_END_DATE" Width="110" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Invoice Status" MappingName="I_T_INVOICE_STATUS" Width="120" AllowEditing="False" TextAlignment="Center" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>
                            <syncfusion:GridTextColumn HeaderText="Payment Method" MappingName="I_PAYMENT_METHOD" Width="140" AllowEditing="False" HeaderStyle="{StaticResource DWInvoiceHeaderStyle}"/>

                        </syncfusion:SfDataGrid.Columns>
                    </syncfusion:SfDataGrid>

                    <!-- Footer load more button (shown when scrolled to bottom) -->
                    <Button x:Name="LoadMoreFooterButton"
                            Grid.Row="2"
                            Content="Charger plus de données"
                            Margin="430,0,0,0"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            Click="LoadMoreButton_Click" Grid.Column="1"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Floating toast notification (enhanced) -->
        <Border x:Name="ToastPanel"
                Grid.RowSpan="2"
                Background="#DD1E1E1E"
                BorderBrush="#4CAF50"
                BorderThickness="2"
                CornerRadius="8"
                Padding="12,8"
                Margin="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Visibility="Collapsed"
                Panel.ZIndex="1000"
                MouseLeftButtonUp="ToastPanel_MouseLeftButtonUp"
                Cursor="Hand">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✨" FontSize="16" Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="ToastText" Text="" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" MaxWidth="400"/>
                <TextBlock Text="→" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#4CAF50" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
