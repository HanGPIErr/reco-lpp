<Project Sdk="Microsoft.NET.Sdk">

  <!-- ============================================================
       Migration .NET Framework 4.8 → .NET 8 (Windows Desktop)
       Old csproj saved as RecoTool.csproj.netfx48.bak
       ============================================================ -->

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- LTS, supported until Nov 2026. Use net9.0-windows later if needed. -->
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>RecoTool</RootNamespace>
    <AssemblyName>RecoTool</AssemblyName>

    <!-- WPF + WinForms (the API/* files use System.Windows.Forms.MessageBox). -->
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>

    <!-- The codebase isn't nullable-aware. Keep disabled to avoid a wave of warnings. -->
    <Nullable>disable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>

    <Platforms>AnyCPU;x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>

    <Configurations>Debug;Release;UAT</Configurations>
    <Deterministic>true</Deterministic>

    <!-- Preserve GUID so any external tooling (CI scripts, .sln) keeps resolving the project. -->
    <ProjectGuid>{3F01CF30-3A41-4316-9C2C-DB0BDC46FF36}</ProjectGuid>

    <ApplicationIcon>RT.ICO</ApplicationIcon>
    <!-- StartupObject is auto-detected from App.xaml (ApplicationDefinition) by the WPF SDK. -->
    <!-- <StartupObject>RecoTool.App</StartupObject> -->

    <!-- Server GC: long-running ops (enrichers, OLE DB reader loops) allocate a lot.
         Server GC uses larger heap segments and collects concurrently with less stutter
         on scroll. We pair with ConcurrentGC + DATAS (set via RuntimeHostConfigurationOption
         below — see ItemGroup at the bottom of the file). -->
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <ConcurrentGarbageCollection>true</ConcurrentGarbageCollection>

    <!-- Tiered compilation + dynamic PGO: hot loops (enrichers, ApplyFilters, ComputeMatched)
         get re-JIT'ted with profile feedback after warmup. Default-on in .NET 8 but explicit. -->
    <TieredCompilation>true</TieredCompilation>
    <TieredPGO>true</TieredPGO>

    <!-- WPF SDK-style auto-discovers .xaml + .xaml.cs files. We keep an explicit
         list below for non-default folders (Properties\Settings.Designer.cs etc.). -->
    <EnableDefaultCompileItems>true</EnableDefaultCompileItems>
    <EnableDefaultPageItems>true</EnableDefaultPageItems>
    <EnableDefaultApplicationDefinition>true</EnableDefaultApplicationDefinition>

    <!-- Suppress NU1701 for the LiveCharts.Wpf 0.9.7 transitive net46 framework target.
         The package is unmaintained but compiles fine via the WPF compatibility shim.
         If we hit a runtime issue we'll switch to LiveCharts2 (see PROPOSALS.md §7.1). -->
    <NoWarn>$(NoWarn);NU1701;CS1591;CS0618</NoWarn>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>portable</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>$(DefineConstants);DEBUG;TRACE</DefineConstants>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugType>portable</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>$(DefineConstants);TRACE</DefineConstants>
    <!-- ReadyToRun: AOT'd native code for faster startup. Only meaningful on Release. -->
    <PublishReadyToRun>true</PublishReadyToRun>
    <TieredCompilation>true</TieredCompilation>
    <TieredPGO>true</TieredPGO>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'UAT' ">
    <OutputPath>bin\UAT\</OutputPath>
    <DebugType>portable</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>$(DefineConstants);TRACE;UAT_ENV</DefineConstants>
  </PropertyGroup>

  <!-- ============================================================
       NuGet packages
       ============================================================ -->
  <ItemGroup>
    <!-- DI / Configuration / Options (already on 9.0.x, multi-targets net8.0). -->
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="9.0.6" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="9.0.6" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="9.0.6" />
    <PackageReference Include="Microsoft.Extensions.Configuration.FileExtensions" Version="9.0.6" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="9.0.6" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.6" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="9.0.6" />

    <!-- ApplicationSettingsBase (used by Properties\Settings.Designer.cs) — moved out
         of the BCL since .NET Core. Keeps App.config userSettings working. -->
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.6" />

    <!-- WebView (Blazor & WebView2) — kept on 9.0.x to match other Microsoft.Extensions packages. -->
    <PackageReference Include="Microsoft.AspNetCore.Components.WebView.Wpf" Version="9.0.100" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3405.78" />

    <!-- JSON: keep Newtonsoft for legacy code paths. New code should prefer System.Text.Json
         (already in the BCL on .NET 8). -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />

    <!-- OleDb is no longer in the BCL since .NET Core. Mandatory for the Access provider. -->
    <PackageReference Include="System.Data.OleDb" Version="9.0.0" />

    <!-- Charting: LiveCharts v1 is unmaintained but compiles via NuGet's net4x compat shim.
         Migrate to LiveCharts2 or OxyPlot in a follow-up if runtime issues appear. -->
    <PackageReference Include="LiveCharts.Wpf" Version="0.9.7" />

    <!-- Syncfusion grid — 33.x targets net6.0+ natively, no compat shim. -->
    <PackageReference Include="Syncfusion.SfGrid.WPF" Version="33.1.45" />

    <!-- Excel writer (used by some export paths). -->
    <PackageReference Include="ClosedXML" Version="0.102.3" />
  </ItemGroup>

  <!-- ============================================================
       Project references
       ============================================================ -->
  <ItemGroup>
    <ProjectReference Include="..\OfflineFirstAccess\OfflineFirstAccess.csproj" />
  </ItemGroup>

  <!-- ============================================================
       Office Interop — IMPORTANT NOTE for .NET 8
       ============================================================
       On .NET Framework 4.8 these were resolved from the GAC via
       `<Reference Include="Microsoft.Office.Interop.X, Version=15.0.0.0, ..." />`.
       .NET 8 does NOT use the GAC, so we instead:
         - reference the PIA DLLs directly via HintPath (Private=true → copied next
           to the .exe so the loader finds them);
         - resolve them at build time from the standard VS Tools for Office PIA
           folder (the same files Office's "Tools for VBA / VS Tools" installs).

       If a PIA file is missing on a build machine, install:
         "Microsoft Visual Studio Tools for Office Runtime" + a recent Office,
       OR copy the .dll's manually into a `lib/Office15` folder under the project
       and adjust the HintPath below.
       ============================================================ -->
  <PropertyGroup>
    <OfficePIAFolder Condition="'$(OfficePIAFolder)' == '' AND Exists('$(MSBuildProgramFiles32)\Microsoft Visual Studio\Shared\Visual Studio Tools for Office\PIA\Office15')">$(MSBuildProgramFiles32)\Microsoft Visual Studio\Shared\Visual Studio Tools for Office\PIA\Office15</OfficePIAFolder>
    <OfficePIAFolder Condition="'$(OfficePIAFolder)' == '' AND Exists('$(MSBuildProgramFiles32)\Microsoft Visual Studio\Shared\Visual Studio Tools for Office\PIA\Office16')">$(MSBuildProgramFiles32)\Microsoft Visual Studio\Shared\Visual Studio Tools for Office\PIA\Office16</OfficePIAFolder>
    <!-- Fallback to GAC location (works because we still copy the file via Private=true). -->
    <OfficePIAFolder Condition="'$(OfficePIAFolder)' == ''">$(WinDir)\assembly\GAC_MSIL</OfficePIAFolder>
  </PropertyGroup>

  <ItemGroup>
    <!-- Microsoft.Office.Interop.Excel PIA -->
    <Reference Include="Microsoft.Office.Interop.Excel" Condition="Exists('$(OfficePIAFolder)\Microsoft.Office.Interop.Excel.dll')">
      <HintPath>$(OfficePIAFolder)\Microsoft.Office.Interop.Excel.dll</HintPath>
      <EmbedInteropTypes>True</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>
    <Reference Include="Microsoft.Office.Interop.Excel" Condition="!Exists('$(OfficePIAFolder)\Microsoft.Office.Interop.Excel.dll') AND Exists('$(WinDir)\assembly\GAC_MSIL\Microsoft.Office.Interop.Excel\15.0.0.0__71e9bce111e9429c\Microsoft.Office.Interop.Excel.dll')">
      <HintPath>$(WinDir)\assembly\GAC_MSIL\Microsoft.Office.Interop.Excel\15.0.0.0__71e9bce111e9429c\Microsoft.Office.Interop.Excel.dll</HintPath>
      <EmbedInteropTypes>True</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>

    <!-- Microsoft.Office.Interop.Access PIA -->
    <Reference Include="Microsoft.Office.Interop.Access" Condition="Exists('$(OfficePIAFolder)\Microsoft.Office.Interop.Access.dll')">
      <HintPath>$(OfficePIAFolder)\Microsoft.Office.Interop.Access.dll</HintPath>
      <EmbedInteropTypes>True</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>
    <Reference Include="Microsoft.Office.Interop.Access" Condition="!Exists('$(OfficePIAFolder)\Microsoft.Office.Interop.Access.dll') AND Exists('$(WinDir)\assembly\GAC_MSIL\Microsoft.Office.Interop.Access\15.0.0.0__71e9bce111e9429c\Microsoft.Office.Interop.Access.dll')">
      <HintPath>$(WinDir)\assembly\GAC_MSIL\Microsoft.Office.Interop.Access\15.0.0.0__71e9bce111e9429c\Microsoft.Office.Interop.Access.dll</HintPath>
      <EmbedInteropTypes>True</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>

    <!-- Microsoft.Office.Interop.Access.Dao PIA — the one that errored.
         EmbedInteropTypes=False mirrors the original Framework reference so
         that `using DAO = Microsoft.Office.Interop.Access.Dao;` keeps a real
         linked assembly (rather than embedded types, which would break the
         DBEngineClass coclass new-up).  -->
    <Reference Include="Microsoft.Office.Interop.Access.Dao" Condition="Exists('$(OfficePIAFolder)\Microsoft.Office.Interop.Access.Dao.dll')">
      <HintPath>$(OfficePIAFolder)\Microsoft.Office.Interop.Access.Dao.dll</HintPath>
      <EmbedInteropTypes>False</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>
    <Reference Include="Microsoft.Office.Interop.Access.Dao" Condition="!Exists('$(OfficePIAFolder)\Microsoft.Office.Interop.Access.Dao.dll') AND Exists('$(WinDir)\assembly\GAC_MSIL\Microsoft.Office.Interop.Access.Dao\15.0.0.0__71e9bce111e9429c\Microsoft.Office.Interop.Access.Dao.dll')">
      <HintPath>$(WinDir)\assembly\GAC_MSIL\Microsoft.Office.Interop.Access.Dao\15.0.0.0__71e9bce111e9429c\Microsoft.Office.Interop.Access.Dao.dll</HintPath>
      <EmbedInteropTypes>False</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>

    <!-- Office.Core (used by Excel automation) -->
    <Reference Include="office" Condition="Exists('$(OfficePIAFolder)\office.dll')">
      <HintPath>$(OfficePIAFolder)\office.dll</HintPath>
      <EmbedInteropTypes>True</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>
    <Reference Include="office" Condition="!Exists('$(OfficePIAFolder)\office.dll') AND Exists('$(WinDir)\assembly\GAC_MSIL\office\15.0.0.0__71e9bce111e9429c\office.dll')">
      <HintPath>$(WinDir)\assembly\GAC_MSIL\office\15.0.0.0__71e9bce111e9429c\office.dll</HintPath>
      <EmbedInteropTypes>True</EmbedInteropTypes>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <!-- ============================================================
       Resources / static files
       ============================================================ -->
  <ItemGroup>
    <Resource Include="RT.ICO" />
  </ItemGroup>

  <!-- Properties\Settings.settings + .Designer.cs are wired by SDK-style WPF.
       Settings.Designer.cs is auto-included via EnableDefaultCompileItems. -->
  <ItemGroup>
    <None Update="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
    <Compile Update="Properties\Settings.Designer.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>Settings.settings</DependentUpon>
    </Compile>
    <None Update="App.config">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="secrets.config" Condition="Exists('secrets.config')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="secrets.config.template" Condition="Exists('secrets.config.template')">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Exclude *.csproj.netfx48.bak from the build output. -->
  <ItemGroup>
    <None Remove="**\*.netfx48.bak" />
    <Compile Remove="**\*.netfx48.bak" />
  </ItemGroup>

  <!-- ============================================================
       Diagnostic: print the resolved Office PIA folder during build
       so that missing PIAs get caught early instead of at runtime.
       ============================================================ -->
  <Target Name="PrintOfficePIAResolution" BeforeTargets="ResolveAssemblyReferences">
    <Message Importance="high" Text="[RecoTool] OfficePIAFolder = $(OfficePIAFolder)" />
    <Message Importance="high" Condition="!Exists('$(OfficePIAFolder)\Microsoft.Office.Interop.Access.Dao.dll') AND !Exists('$(WinDir)\assembly\GAC_MSIL\Microsoft.Office.Interop.Access.Dao\15.0.0.0__71e9bce111e9429c\Microsoft.Office.Interop.Access.Dao.dll')"
             Text="[RecoTool] WARNING: Microsoft.Office.Interop.Access.Dao.dll NOT FOUND in either '$(OfficePIAFolder)' or the legacy GAC path. Build will fail with 'The type or namespace DAO does not exist'. Install Microsoft Visual Studio Tools for Office Runtime, or copy the PIA dll into a 'lib' folder under the project and adjust HintPath." />
  </Target>

  <!-- ============================================================
       runtimeconfig.json options — emitted next to the .exe
       ============================================================ -->
  <ItemGroup>
    <!-- DATAS (Dynamic Adaptation To Application Sizes) — .NET 8 GC tunes heap size to
         memory pressure. Big win on long-running desktop apps that swing between idle
         and burst (your enrichment passes). -->
    <RuntimeHostConfigurationOption Include="System.GC.DynamicAdaptationMode" Value="1" />

    <!-- Globalization invariant mode is OFF (we parse fr-FR / it-IT dates in DwingsDateHelper). -->
    <RuntimeHostConfigurationOption Include="System.Globalization.Invariant" Value="false" />

    <!-- Allow loading legacy ICU/NLS for date/string parsing. .NET 8 default already does
         this on Windows, listed for clarity / future-proofing. -->
    <RuntimeHostConfigurationOption Include="System.Globalization.UseNls" Value="true" />
  </ItemGroup>

</Project>
